@using MudBlazor
@using System.Globalization
@using TCSA.KnowTheCity.Theme
@inherits LayoutComponentBase
@implements IDisposable
@inject IStringLocalizer<SharedResource> Localizer
@inject AppLocalizationService LocalizationService

<div class="@AppShellClass">
    <MudThemeProvider Theme="@AppTheme.Default" IsDarkMode="@_isDarkMode" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <MudLayout>
        <MudAppBar Bottom="true" Fixed="true" Dense="true" Elevation="0">
            <MudContainer MaxWidth="MaxWidth.Large" Class="d-flex align-center px-0">
                <MudIconButton Icon="@Icons.Material.Filled.Home"
                               Variant="Variant.Text"
                               Color="Color.Inherit"
                               Href="/" />

                <MudSpacer />

                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                    <MudText Typo="Typo.h6">@Localizer["App.Title"]</MudText>
                </MudHidden>

                <MudSpacer />

                <MudIconButton Icon="@ThemeToggleIcon"
                               Variant="Variant.Text"
                               Color="Color.Inherit"
                               OnClick="ToggleTheme"
                               Class="mx-1" />
                <MudIconButton Icon="@Icons.Material.Filled.Settings"
                               Variant="Variant.Text"
                               Color="Color.Inherit"
                               Href="/settings"
                               Class="mx-1" />
                <MudIconButton Icon="@Icons.Material.Filled.Info"
                               Variant="Variant.Text"
                               Color="Color.Inherit"
                               Href="/instructions"
                               Class="mx-1" />
                <MudIconButton Icon="@Icons.Material.Filled.Favorite"
                               Variant="Variant.Text"
                               Color="Color.Inherit"
                               Href="/favorites"
                               Class="mx-1" />
                <MudIconButton Icon="@Icons.Material.Filled.History"
                               Variant="Variant.Text"
                               Color="Color.Inherit"
                               Href="/history"
                               Class="mx-1" />
            </MudContainer>
        </MudAppBar>

        <MudMainContent Class="pa-4 mt-2">
            <div @key="_cultureRenderKey">
                @Body
            </div>
        </MudMainContent>
    </MudLayout>
</div>

@code {
    private bool _isDarkMode = Microsoft.Maui.Controls.Application.Current?.RequestedTheme == Microsoft.Maui.ApplicationModel.AppTheme.Dark;
    private int _cultureRenderKey;

    private string AppShellClass => _isDarkMode ? "app-shell app-theme-dark" : "app-shell app-theme-light";

    private string ThemeToggleIcon => _isDarkMode
        ? Icons.Material.Filled.LightMode
        : Icons.Material.Filled.DarkMode;

    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
    }

    protected override void OnInitialized()
    {
        LocalizationService.CultureChanged += OnCultureChanged;
    }

    private void OnCultureChanged()
    {
        _ = InvokeAsync(() =>
        {
            var culture = CultureInfo.GetCultureInfo(LocalizationService.CurrentCultureName);
            CultureInfo.CurrentCulture = culture;
            CultureInfo.CurrentUICulture = culture;
            _cultureRenderKey++;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        LocalizationService.CultureChanged -= OnCultureChanged;
    }
}
