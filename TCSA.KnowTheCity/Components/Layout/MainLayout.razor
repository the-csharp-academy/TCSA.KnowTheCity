@using MudBlazor
@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Bottom="true" Color="Color.Success" Fixed="true" Elevation="2" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.Home"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="/" />
        <MudSpacer />
        <MudText Typo="Typo.h6">Know The City</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.MenuBook"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="/study" />
        <MudIconButton Icon="@Icons.Material.Filled.History"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="/history" />
    </MudAppBar>

    <MudMainContent Class="pa-4 mt-2">
        @Body
    </MudMainContent>
</MudLayout>
