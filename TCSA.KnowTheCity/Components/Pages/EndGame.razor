@page "/results/{GameResultId:int}"
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Models
@using TCSA.KnowTheCity.Services

<MudContainer MaxWidth="MaxWidth.Small">
    @if (gameResult is null)
    {
        <MudProgressCircular Indeterminate="true" Class="d-flex mx-auto mt-8" />
    }
    else
    {
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">
            @(gameResult.CorrectCount == gameResult.TotalCount ? "?? Perfect Score!" : "Quiz Complete!")
        </MudText>

        <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-2">
            You got <b>@gameResult.CorrectCount</b> out of <b>@gameResult.TotalCount</b> landmarks
        </MudText>

        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary" Class="mb-4">
            @gameResult.City · @gameResult.PlayedAt.ToString("MMM dd, yyyy HH:mm")
        </MudText>

        <MudDivider Class="mb-4" />

        <MudList T="string">
            @foreach (var item in gameResult.Items)
            {
                var landmarkId = cityInfo?.Landmarks.FirstOrDefault(l => l.Name == item.Landmark)?.Id;
                var isFav = landmarkId is not null && favoriteLandmarkKeys.Contains((cityInfo!.Id, landmarkId));

                <MudListItem Icon="@(item.IsCorrect ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             IconColor="@(item.IsCorrect ? Color.Success : Color.Error)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText>@item.Landmark</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            @if (!item.IsCorrect)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                    @item.Label
                                </MudChip>
                            }
                            @if (landmarkId is not null)
                            {
                                <MudIconButton Icon="@(isFav ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                                               Color="@(isFav ? Color.Error : Color.Default)"
                                               Size="Size.Small"
                                               OnClick="() => ToggleFavoriteLandmarkAsync(landmarkId)" />
                            }
                        </MudStack>
                    </MudStack>
                </MudListItem>
            }
        </MudList>

        <MudDivider Class="mb-4 mt-2" />

        <MudGrid>
            <MudItem xs="6">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           FullWidth="true" Href="@($"/quiz/{gameResult.City}")"
                           StartIcon="@Icons.Material.Filled.Replay">
                    Play Again
                </MudButton>
            </MudItem>
            <MudItem xs="6">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true" Href="/"
                           StartIcon="@Icons.Material.Filled.Home">
                    Home
                </MudButton>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter]
    public int GameResultId { get; set; }

    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private IFavoriteService FavoriteService { get; set; } = default!;

    private GameResult? gameResult;
    private CityInfo? cityInfo;
    private HashSet<(string CityId, string LandmarkId)> favoriteLandmarkKeys = [];

    protected override async Task OnInitializedAsync()
    {
        gameResult = await GameService.GetGameResultAsync(GameResultId);

        if (gameResult is not null)
        {
            cityInfo = CityDataHelper.Cities.FirstOrDefault(c => c.Name == gameResult.City);

            if (cityInfo is not null)
            {
                var favorites = await FavoriteService.GetFavoriteLandmarksAsync(cityInfo.Id);
                favoriteLandmarkKeys = [.. favorites.Select(f => (f.CityId, f.LandmarkId))];
            }
        }
    }

    private async Task ToggleFavoriteLandmarkAsync(string landmarkId)
    {
        if (cityInfo is null) return;

        var key = (cityInfo.Id, landmarkId);
        if (favoriteLandmarkKeys.Contains(key))
        {
            await FavoriteService.RemoveFavoriteLandmarkAsync(cityInfo.Id, landmarkId);
            favoriteLandmarkKeys.Remove(key);
        }
        else
        {
            await FavoriteService.AddFavoriteLandmarkAsync(cityInfo.Id, landmarkId);
            favoriteLandmarkKeys.Add(key);
        }
    }
}