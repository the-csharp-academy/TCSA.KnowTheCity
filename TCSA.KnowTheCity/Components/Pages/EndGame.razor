@page "/results/{GameResultId:int}"
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Services
@inject IStringLocalizer<SharedResource> Localizer

<MudContainer MaxWidth="MaxWidth.Medium" Class="pb-8 endgame-shell-container">
    @if (_gameResult is null)
    {
        <MudPaper Elevation="6" Class="quiz-loading-shell py-10 px-6 rounded-xl">
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.h6">@Localizer["EndGame.LoadingResults"]</MudText>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudPaper Elevation="0" Class="endgame-hero mb-6">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h4" Class="endgame-hero-title">
                    @GetHeadlineTitle()
                </MudText>

                <MudText Typo="Typo.body1" Class="endgame-hero-subtitle">
                    @Localizer["EndGame.Subtitle", _gameResult.CorrectCount, _gameResult.TotalCount, _city?.Name ?? string.Empty]
                </MudText>
            </MudStack>
        </MudPaper>

        <MudGrid Class="mb-4">
            <MudItem xs="4">
                <MudPaper Elevation="0" Class="endgame-stat-card endgame-stat-card-score pa-4">
                    <MudText Typo="Typo.overline" Class="endgame-stat-label">@Localizer["EndGame.ScoreLabel"]</MudText>
                    <MudText Typo="Typo.h4" Class="endgame-stat-value">@_gameResult.CorrectCount/@_gameResult.TotalCount</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Elevation="0" Class="endgame-stat-card endgame-stat-card-accuracy pa-4">
                    <MudText Typo="Typo.overline" Class="endgame-stat-label">@Localizer["EndGame.AccuracyLabel"]</MudText>
                    <MudText Typo="Typo.h4" Class="endgame-stat-value">@GetAccuracyText()</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Elevation="0" Class="endgame-stat-card endgame-stat-card-city pa-4">
                    <MudText Typo="Typo.overline" Class="endgame-stat-label">@Localizer["EndGame.CityLabel"]</MudText>
                    <MudText Typo="Typo.h6" Class="endgame-stat-value">@_city?.Name</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Elevation="0" Class="endgame-results-shell pa-4">
            <MudText Typo="Typo.h6" Class="endgame-section-title mb-3">
                @Localizer["EndGame.BreakdownTitle"]
            </MudText>

            <div class="endgame-result-list">
                @foreach (var item in _gameResult.Items)
                {
                    var isFav = _favoriteLandmarkKeys.Contains((_city!.Id, item.Landmark.Id));

                    <div class="endgame-result-row @(item.IsCorrect ? "endgame-result-row-correct" : "endgame-result-row-wrong")">
                        <div class="endgame-result-icon @(item.IsCorrect ? "endgame-result-icon-correct" : "endgame-result-icon-wrong")">
                            <MudIcon Icon="@(item.IsCorrect ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)" />
                        </div>

                        <div class="endgame-result-content">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6" Class="endgame-result-title">@item.Landmark.Name</MudText>

                                <MudHidden Breakpoint="Breakpoint.SmAndDown">
                                    @if (!item.IsCorrect && !string.IsNullOrWhiteSpace(item.Label))
                                    {
                                        <MudChip T="string"
                                                 Class="endgame-status-chip endgame-status-chip-detail"
                                                 Variant="Variant.Filled"
                                                 Size="Size.Small">
                                            @GetResultLabel(item.Label)
                                        </MudChip>
                                    }
                                </MudHidden>
                            </MudStack>
                        </div>

                        <MudIconButton Icon="@(isFav? Icons.Material.Filled.Favorite : Icons.Material.Outlined.StarBorder)"
                                       Class="@(isFav ? "endgame-favorite-button is-active" : "endgame-favorite-button")"
                                       Size="Size.Medium"
                                       OnClick="() => ToggleFavoriteLandmarkAsync(item.Landmark.Id)" />
                    </div>
                }
            </div>
        </MudPaper>

        <MudGrid Class="mt-4">
            <MudItem xs="6">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Href="@($"/quiz/{_city?.Id}")"
                           StartIcon="@Icons.Material.Filled.Replay"
                           Class="quiz-action-button">
                    @Localizer["EndGame.PlayAgain"]
                </MudButton>
            </MudItem>
            <MudItem xs="6">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           FullWidth="true"
                           Href="/"
                           StartIcon="@Icons.Material.Filled.Home"
                           Class="quiz-action-button">
                    @Localizer["EndGame.Home"]
                </MudButton>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter]
    public int GameResultId { get; set; }

    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private IFavoriteService FavoriteService { get; set; } = default!;

    [Inject]
    private ICityService CityService { get; set; } = default!;

    private GameResult? _gameResult;
    private City? _city;
    private HashSet<(int CityId, int LandmarkId)> _favoriteLandmarkKeys = [];

    protected override async Task OnInitializedAsync()
    {
        _gameResult = await GameService.GetGameResultAsync(GameResultId);

        if (_gameResult is not null)
        {
            _city = _gameResult.City;

            var favorites = await FavoriteService.GetFavoriteLandmarksAsync(_city.Id);
            _favoriteLandmarkKeys = [.. favorites.Select(f => (f.CityId, f.LandmarkId))];
        }
    }

    private string GetHeadlineTitle()
    {
        if (_gameResult is null)
            return string.Empty;

        return _gameResult.CorrectCount == _gameResult.TotalCount
            ? Localizer["EndGame.Headline.Perfect"].Value
            : GetAccuracy() >= 70
                ? Localizer["EndGame.Headline.Great"].Value
                : Localizer["EndGame.Headline.Nice"].Value;
    }

    private int GetAccuracy()
    {
        if (_gameResult is null || _gameResult.TotalCount == 0)
            return 0;

        return (int)Math.Round((_gameResult.CorrectCount / (double)_gameResult.TotalCount) * 100);
    }

    private string GetAccuracyText() => $"{GetAccuracy()}%";

    private string GetResultLabel(string? label)
    {
        if (string.IsNullOrWhiteSpace(label))
            return string.Empty;

        var parts = label.Split('|', 2, StringSplitOptions.TrimEntries);
        var resourceKey = parts[0];
        var baseLabel = Localizer[resourceKey].Value;

        return parts.Length == 2
            ? Localizer["Quiz.ResultLabel.WithCity", baseLabel, parts[1]].Value
            : baseLabel;
    }

    private async Task ToggleFavoriteLandmarkAsync(int landmarkId)
    {
        if (_city is null)
            return;

        var key = (_city.Id, landmarkId);

        if (_favoriteLandmarkKeys.Contains(key))
        {
            await FavoriteService.RemoveFavoriteLandmarkAsync(_city.Id, landmarkId);
            _favoriteLandmarkKeys.Remove(key);
        }
        else
        {
            await FavoriteService.AddFavoriteLandmarkAsync(_city.Id, landmarkId);
            _favoriteLandmarkKeys.Add(key);
        }
    }
}