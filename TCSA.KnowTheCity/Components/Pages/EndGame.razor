@page "/results/{GameResultId:int}"
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Services

<MudContainer MaxWidth="MaxWidth.Small">
    @if (_gameResult is null)
    {
        <MudProgressCircular Indeterminate="true" Class="d-flex mx-auto mt-8" />
    }
    else
    {
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">
            @(_gameResult.CorrectCount == _gameResult.TotalCount ? "?? Perfect Score!" : "Quiz Complete!")
        </MudText>

        <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-2">
            You got <b>@_gameResult.CorrectCount</b> out of <b>@_gameResult.TotalCount</b> landmarks
        </MudText>

        <MudDivider Class="mb-4" />

        <MudList T="string">
            @foreach (var item in _gameResult.Items)
            {
                var isFav = _favoriteLandmarkKeys.Contains((_city!.Id, item.Landmark.Id));

                <MudListItem Icon="@(item.IsCorrect? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                             IconColor="@(item.IsCorrect? Color.Success: Color.Error)"
                             IconSize="Size.Large">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.h5">@item.Landmark.Name</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            @if (!item.IsCorrect)
                            {
                                <MudChip T="string" Size="Size.Medium" Color="Color.Error" Variant="Variant.Outlined">
                                    @item.Label
                                </MudChip>
                            }
                            <MudIconButton Icon="@(isFav? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                           Style="@(isFav ? "color: #FFD700;" : "")"
                                           Size="Size.Large"
                                           OnClick="() => ToggleFavoriteLandmarkAsync(item.Landmark.Id)" />
                        </MudStack>
                    </MudStack>
                </MudListItem>
            }
        </MudList>

        <MudDivider Class="mb-4 mt-2" />

        <MudGrid>
            <MudItem xs="6">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           FullWidth="true" Href="@($"/quiz/{_city?.Id}")"
                           StartIcon="@Icons.Material.Filled.Replay">
                    Play Again
                </MudButton>
            </MudItem>
            <MudItem xs="6">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true" Href="/"
                           StartIcon="@Icons.Material.Filled.Home">
                    Home
                </MudButton>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

    @code {
    [Parameter]
    public int GameResultId { get; set; }

    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private IFavoriteService FavoriteService { get; set; } = default!;

    [Inject]
    private ICityService CityService { get; set; } = default!;

    private GameResult? _gameResult;
    private City? _city;
    private HashSet<(int CityId, int LandmarkId)> _favoriteLandmarkKeys = [];

    protected override async Task OnInitializedAsync()
    {
        _gameResult = await GameService.GetGameResultAsync(GameResultId);

        if (_gameResult is not null)
        {
            _city = _gameResult.City;

            var favorites = await FavoriteService.GetFavoriteLandmarksAsync(_city.Id);
                _favoriteLandmarkKeys = [.. favorites.Select(f => (f.CityId, f.LandmarkId))];
        }
    }

    private async Task ToggleFavoriteLandmarkAsync(int landmarkId)
    {
        if (_city is null) return;

        var key = (_city.Id, landmarkId);
        if (_favoriteLandmarkKeys.Contains(key))
        {
            await FavoriteService.RemoveFavoriteLandmarkAsync(_city.Id, landmarkId);
            _favoriteLandmarkKeys.Remove(key);
        }
        else
        {
            await FavoriteService.AddFavoriteLandmarkAsync(_city.Id, landmarkId);
            _favoriteLandmarkKeys.Add(key);
        }
    }
}