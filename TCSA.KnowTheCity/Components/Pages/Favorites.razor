@page "/favorites"
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Services

<MudContainer MaxWidth="MaxWidth.Large" Class="pb-8">
    <MudPaper Elevation="0" Class="favorites-hero mb-6">
        <MudStack Spacing="3">
            <MudChip T="string" Class="home-hero-chip" Variant="Variant.Filled" Size="Size.Medium">
                Saved Places
            </MudChip>

            <MudText Typo="Typo.h4" Class="favorites-hero-title">
                Keep your favourite places close
            </MudText>

            <MudText Typo="Typo.body1" Class="favorites-hero-subtitle">
                Review the cities and landmarks you saved, then remove anything you no longer want to keep.
            </MudText>

            <MudStack Row="true" Spacing="2">
                <MudChip T="string" Class="brand-chip brand-chip-gold" Variant="Variant.Filled">
                    Cities saved: @_favoriteCities.Count
                </MudChip>
                <MudChip T="string" Class="brand-chip brand-chip-orange" Variant="Variant.Filled">
                    Landmarks saved: @_favoriteLandmarks.Count
                </MudChip>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="favorites-panel h-100">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudPaper Elevation="0" Class="favorites-icon-badge favorites-icon-badge-cities">
                            <MudIcon Icon="@Icons.Material.Filled.Favorite" />
                        </MudPaper>

                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6" Class="favorites-panel-title">
                                Favourite Cities
                            </MudText>
                            <MudText Typo="Typo.body2" Class="favorites-panel-subtitle">
                                Cities you've saved for later.
                            </MudText>
                        </MudStack>
                    </MudStack>

                    <MudChip T="string" Class="favorites-count-chip" Variant="Variant.Filled">
                        @_favoriteCities.Count
                    </MudChip>
                </MudStack>

                @if (_favoriteCities.Count == 0)
                {
                    <MudPaper Elevation="0" Class="favorites-empty-state">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.FavoriteBorder" Size="Size.Large" Class="favorites-empty-icon" />
                            <MudText Typo="Typo.subtitle1" Class="favorites-empty-title">
                                No favourite cities yet
                            </MudText>
                            <MudText Typo="Typo.body2" Class="favorites-empty-text">
                                Start saving cities from the home screen and they will appear here.
                            </MudText>
                        </MudStack>
                    </MudPaper>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var city in _favoriteCities)
                        {
                            var cityName = _cities.FirstOrDefault(c => c.Id == city.CityId)?.Name ?? city.CityId.ToString();

                            <MudPaper Elevation="0" Class="favorites-item">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.subtitle1" Class="favorites-item-title">@cityName</MudText>
                                        <MudText Typo="Typo.caption" Class="favorites-item-subtitle">Saved city</MudText>
                                    </MudStack>

                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   Class="favorites-delete-button"
                                                   OnClick="() => RemoveFavoriteCityAsync(city.CityId)" />
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Elevation="0" Class="favorites-panel h-100">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudPaper Elevation="0" Class="favorites-icon-badge favorites-icon-badge-landmarks">
                            <MudIcon Icon="@Icons.Material.Filled.Place" />
                        </MudPaper>

                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6" Class="favorites-panel-title">
                                Favourite Landmarks
                            </MudText>
                            <MudText Typo="Typo.body2" Class="favorites-panel-subtitle">
                                Landmarks you've marked as must-see.
                            </MudText>
                        </MudStack>
                    </MudStack>

                    <MudChip T="string" Class="favorites-count-chip" Variant="Variant.Filled">
                        @_favoriteLandmarks.Count
                    </MudChip>
                </MudStack>

                @if (_favoriteLandmarks.Count == 0)
                {
                    <MudPaper Elevation="0" Class="favorites-empty-state">
                        <MudStack AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Large" Class="favorites-empty-icon" />
                            <MudText Typo="Typo.subtitle1" Class="favorites-empty-title">
                                No favourite landmarks yet
                            </MudText>
                            <MudText Typo="Typo.body2" Class="favorites-empty-text">
                                Save landmarks during the quiz flow and they will show up here.
                            </MudText>
                        </MudStack>
                    </MudPaper>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var landmark in _favoriteLandmarks)
                        {
                            var city = _cities.FirstOrDefault(c => c.Id == landmark.CityId);
                            var landmarkName = city?.Landmarks.FirstOrDefault(l => l.Id == landmark.LandmarkId)?.Name ?? landmark.LandmarkId.ToString();
                            var cityName = city?.Name ?? landmark.CityId.ToString();

                            <MudPaper Elevation="0" Class="favorites-item">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="2">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle1" Class="favorites-item-title">@landmarkName</MudText>
                                        <MudChip T="string" Class="favorites-city-chip" Variant="Variant.Filled" Size="Size.Small">
                                            @cityName
                                        </MudChip>
                                    </MudStack>

                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   Class="favorites-delete-button"
                                                   OnClick="() => RemoveFavoriteLandmarkAsync(landmark.CityId, landmark.LandmarkId)" />
                                </MudStack>
                            </MudPaper>
                        }
                    </MudStack>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Inject]
    private IFavoriteService FavoriteService { get; set; } = default!;

    [Inject]
    private ICityService CityService { get; set; } = default!;

    private List<City> _cities = [];
    private List<FavoriteCity> _favoriteCities = [];
    private List<FavoriteLandmark> _favoriteLandmarks = [];

    protected override async Task OnInitializedAsync()
    {
        _cities = await CityService.GetCitiesAsync();
        await LoadFavoritesAsync();
    }

    private async Task LoadFavoritesAsync()
    {
        _favoriteCities = await FavoriteService.GetFavoriteCitiesAsync();
        _favoriteLandmarks = await FavoriteService.GetFavoriteLandmarksAsync();
    }

    private async Task RemoveFavoriteCityAsync(int cityId)
    {
        await FavoriteService.RemoveFavoriteCityAsync(cityId);
        _favoriteCities.RemoveAll(f => f.CityId == cityId);
    }

    private async Task RemoveFavoriteLandmarkAsync(int cityId, int landmarkId)
    {
        await FavoriteService.RemoveFavoriteLandmarkAsync(cityId, landmarkId);
        _favoriteLandmarks.RemoveAll(f => f.CityId == cityId && f.LandmarkId == landmarkId);
    }
}