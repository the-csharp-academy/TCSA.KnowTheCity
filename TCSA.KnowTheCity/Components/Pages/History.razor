@page "/history"
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Services

<MudContainer Class="mt-5" MaxWidth="MaxWidth.Large">
    <MudGrid>

        <!-- Left: Search panel -->
        <MudItem xs="12" sm="4" md="3">
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Search</MudText>

                <MudSelect T="int?"
                           Label="City"
                           Variant="Variant.Outlined"
                           @bind-Value="_selectedCityId"
                           Clearable="true"
                           Dense="true"
                           Class="mb-4">
                    @foreach (var city in _availableCities)
                    {
                        <MudSelectItem Value="@((int?)city.Id)">@city.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudDatePicker Label="From Date"
                               Variant="Variant.Outlined"
                               @bind-Date="_fromDate"
                               Clearable="true"
                               Class="mb-4" />

                <MudDatePicker Label="To Date"
                               Variant="Variant.Outlined"
                               @bind-Date="_toDate"
                               Clearable="true"
                               Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="ApplySearch"
                           StartIcon="@Icons.Material.Filled.Search">
                    Search
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           FullWidth="true"
                           OnClick="ClearSearch"
                           StartIcon="@Icons.Material.Filled.Clear"
                           Class="mt-2">
                    Clear
                </MudButton>
            </MudPaper>
        </MudItem>

        <!-- Right: Results -->
        <MudItem xs="12" sm="8" md="9">
            @if (_gameResults.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No games found. Try a different search or go play a quiz!
                </MudAlert>
            }
            else
            {
                <MudTable Items="@_gameResults" Hover="true" Striped="true" Elevation="2">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>City</MudTh>
                        <MudTh>Score</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Date">@context.PlayedAt.ToString("MM/dd/yyyy HH:mm")</MudTd>
                        <MudTd DataLabel="City">@context.City.Name</MudTd>
                        <MudTd DataLabel="Score">
                            <MudChip T="string"
                                     Color="@(context.CorrectCount == context.TotalCount ? Color.Success : Color.Default)"
                                     Variant="Variant.Filled"
                                     Size="Size.Small">
                                @context.Score
                            </MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private ICityService CityService { get; set; } = default!;

    private List<GameResult> _gameResults = [];
    private List<City> _availableCities = [];
    private int? _selectedCityId;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    protected override async Task OnInitializedAsync()
    {
        _availableCities = await CityService.GetCitiesAsync();
        await LoadResultsAsync();
    }

    private async Task ApplySearch()
    {
        await LoadResultsAsync();
    }

    private async Task ClearSearch()
    {
        _selectedCityId = null;
        _fromDate = null;
        _toDate = null;
        await LoadResultsAsync();
    }

    private async Task LoadResultsAsync()
    {
        if (_selectedCityId != null)
        {
            _gameResults = await GameService.GetGameHistoryAsync(_selectedCityId.Value, _fromDate, _toDate);
        }
    }
}