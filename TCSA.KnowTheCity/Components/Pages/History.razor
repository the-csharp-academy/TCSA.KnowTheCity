@page "/history"
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Services
@inject IStringLocalizer<SharedResource> Localizer

<MudContainer MaxWidth="MaxWidth.Large" Class="history-page pb-8">
    <MudPaper Elevation="0" Class="history-hero mb-6">
        <MudStack Spacing="3">
            <MudChip T="string"
                     Class="history-hero-chip"
                     Variant="Variant.Filled"
                     Icon="@Icons.Material.Filled.History">
                @Localizer["History.Tag"]
            </MudChip>

            <MudText Typo="Typo.h4" Class="history-hero-title">
                @Localizer["History.Title"]
            </MudText>

            <MudText Typo="Typo.body1" Class="history-hero-subtitle">
                @Localizer["History.Subtitle"]
            </MudText>

            <MudStack Row="true" Spacing="2" Class="history-hero-chips">
                <MudChip T="string"
                         Class="brand-chip brand-chip-sky"
                         Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.LocationCity">
                    @CityFilterLabel
                </MudChip>

                <MudChip T="string"
                         Class="brand-chip brand-chip-gold"
                         Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.CalendarMonth">
                    @DateRangeLabel
                </MudChip>

                <MudChip T="string"
                         Class="brand-chip brand-chip-orange"
                         Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.Insights">
                    @ResultCountLabel
                </MudChip>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" sm="4" md="3">
            <MudPaper Elevation="4" Class="history-panel history-filter-panel pa-4 h-100">
                <MudText Typo="Typo.h6" Class="history-section-title" GutterBottom="true">
                    <MudIcon Icon="@Icons.Material.Filled.Tune" Class="mr-2" />
                    @Localizer["History.SearchTitle"]
                </MudText>

                <MudText Typo="Typo.body2" Class="history-section-subtitle">
                    @Localizer["History.SearchSubtitle"]
                </MudText>

                <MudDivider Class="my-3" />

                <MudStack Spacing="2">
                    <MudSelect T="int?"
                               Label='@Localizer["History.City"]'
                               Variant="Variant.Outlined"
                               @bind-Value="_selectedCityId"
                               Clearable="true"
                               Dense="true">
                        @foreach (var city in _availableCities)
                        {
                            <MudSelectItem Value="@((int?)city.Id)">@city.Name</MudSelectItem>
                        }
                    </MudSelect>

                    <MudDatePicker Label='@Localizer["History.FromDate"]'
                                   Variant="Variant.Outlined"
                                   @bind-Date="_fromDate"
                                   Clearable="true" />

                    <MudDatePicker Label='@Localizer["History.ToDate"]'
                                   Variant="Variant.Outlined"
                                   @bind-Date="_toDate"
                                   Clearable="true" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Class="history-filter-button"
                               OnClick="ApplySearch"
                               StartIcon="@Icons.Material.Filled.Search">
                        @Localizer["History.Search"]
                    </MudButton>

                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               FullWidth="true"
                               Class="history-clear-button"
                               OnClick="ClearSearch"
                               StartIcon="@Icons.Material.Filled.Clear">
                        @Localizer["History.Clear"]
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="8" md="9">
            <MudPaper Elevation="4" Class="history-panel history-results-panel pa-4">
                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Justify="Justify.SpaceBetween"
                          Class="mb-3">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.h6" Class="history-section-title">
                            <MudIcon Icon="@Icons.Material.Filled.Insights" Class="mr-2" />
                            @Localizer["History.ResultsTitle"]
                        </MudText>

                        <MudText Typo="Typo.body2" Class="history-section-subtitle">
                            @Localizer["History.ResultsSubtitle"]
                        </MudText>
                    </MudStack>

                    <MudChip T="string"
                             Class="history-results-chip"
                             Variant="Variant.Filled">
                        @ResultCountLabel
                    </MudChip>
                </MudStack>

                <MudDivider Class="mb-3" />

                @if (_gameResults.Count == 0)
                {
                    <MudAlert Severity="Severity.Info"
                              Variant="Variant.Outlined"
                              Dense="true"
                              Class="history-empty-state">
                        @Localizer["History.NoGames"]
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="@_gameResults"
                              Hover="true"
                              Striped="true"
                              Elevation="0"
                              Breakpoint="Breakpoint.Sm"
                              Class="history-table">
                        <HeaderContent>
                            <MudTh>@Localizer["History.Date"]</MudTh>
                            <MudTh>@Localizer["History.City"]</MudTh>
                            <MudTh>@Localizer["History.Score"]</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel='@Localizer["History.Date"]'>@context.PlayedAt.ToString("g", System.Globalization.CultureInfo.CurrentCulture)</MudTd>
                            <MudTd DataLabel='@Localizer["History.City"]'>
                                <MudText Class="history-city-name">@context.City.Name</MudText>
                            </MudTd>
                            <MudTd DataLabel='@Localizer["History.Score"]'>
                                <MudChip T="string"
                                         Class="@GetScoreChipClass(context)"
                                         Variant="Variant.Filled"
                                         Size="Size.Small">
                                    @context.Score
                                </MudChip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private ICityService CityService { get; set; } = default!;

    private List<GameResult> _gameResults = [];
    private List<City> _availableCities = [];
    private int? _selectedCityId;
    private DateTime? _fromDate;
    private DateTime? _toDate;

    private string ResultCountLabel =>
        _gameResults.Count == 1
            ? Localizer["History.ResultCount.Singular"].Value
            : Localizer["History.ResultCount.Plural", _gameResults.Count].Value;

    private string CityFilterLabel =>
        _selectedCityId is int cityId
            ? _availableCities.FirstOrDefault(city => city.Id == cityId)?.Name ?? Localizer["History.SelectedCity"].Value
            : Localizer["History.AllCities"].Value;

    private string DateRangeLabel =>
        _fromDate is null && _toDate is null
            ? Localizer["History.AllDates"].Value
            : Localizer["History.DateRange",
                _fromDate?.ToString("d", System.Globalization.CultureInfo.CurrentCulture) ?? Localizer["History.AnyDate"].Value,
                _toDate?.ToString("d", System.Globalization.CultureInfo.CurrentCulture) ?? Localizer["History.AnyDate"].Value].Value;

    protected override async Task OnInitializedAsync()
    {
        _availableCities = await CityService.GetCitiesAsync();
        await LoadResultsAsync();
    }

    private async Task ApplySearch()
    {
        await LoadResultsAsync();
    }

    private async Task ClearSearch()
    {
        _selectedCityId = null;
        _fromDate = null;
        _toDate = null;
        await LoadResultsAsync();
    }

    private async Task LoadResultsAsync()
    {
        _gameResults = await GameService.GetGameHistoryAsync(_selectedCityId, _fromDate, _toDate);
    }

    private static string GetScoreChipClass(GameResult result) =>
        result.CorrectCount == result.TotalCount
            ? "history-score-chip history-score-chip-perfect"
            : "history-score-chip history-score-chip-standard";
}