@page "/history"
@using TCSA.KnowTheCity.Services

<MudContainer MaxWidth="MaxWidth.Small">
    <MudText Typo="Typo.h4" GutterBottom="true">Game History</MudText>

    @if (gameResults.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
            No games played yet. Go play a quiz!
        </MudAlert>
    }
    else
    {
        <MudTable Items="@gameResults" Hover="true" Striped="true" Elevation="2">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>City</MudTh>
                <MudTh>Score</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Date">@context.PlayedAt.ToString("MM/dd/yyyy HH:mm")</MudTd>
                <MudTd DataLabel="City">@context.City</MudTd>
                <MudTd DataLabel="Score">
                    <MudChip T="string"
                             Color="@(context.CorrectCount == context.TotalCount ? Color.Success : Color.Default)"
                             Variant="Variant.Filled"
                             Size="Size.Small">
                        @context.Score
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
</MudContainer>

@code {
    [Inject]
    private IGameService GameService { get; set; } = default!;

    private List<GameResult> gameResults = [];

    protected override async Task OnInitializedAsync()
    {
        gameResults = await GameService.GetGameHistoryAsync();
    }
}