@page "/"
@using TCSA.KnowTheCity.Core.Enums
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Core.Services
@using TCSA.KnowTheCity.Services
@inject IStringLocalizer<SharedResource> Localizer

<MudContainer MaxWidth="MaxWidth.Large" Class="pb-20">
    <MudPaper Elevation="0" Class="home-hero mb-6">
        <div class="home-hero-content">
            <MudStack Spacing="3" Class="home-hero-copy">
                <MudText Typo="Typo.h4" Class="home-hero-title">
                    @Localizer["Home.HeroTitle"]
                </MudText>

                <MudText Typo="Typo.body1" Class="home-hero-subtitle">
                    @Localizer["Home.HeroSubtitle"]
                </MudText>
            </MudStack>

            <MudStack Row="true" Spacing="2" Class="home-hero-chips">
                <MudChip T="string" Class="brand-chip brand-chip-sky" Variant="Variant.Filled">
                    @FormatCount(_totalCityCount, "Home.CityCount.Singular", "Home.CityCount.Plural")
                </MudChip>
                <MudChip T="string" Class="brand-chip brand-chip-orange" Variant="Variant.Filled">
                    @FormatCount(_countries.Count, "Home.CountryCount.Singular", "Home.CountryCount.Plural")
                </MudChip>
                <MudChip T="string" Class="brand-chip brand-chip-gold" Variant="Variant.Filled">
                    @FormatCount(_totalLandmarkCount, "Home.LandmarkCount.Singular", "Home.LandmarkCount.Plural")
                </MudChip>
            </MudStack>
        </div>
    </MudPaper>

    <MudPaper Elevation="0" Class="mb-6 pa-4">
        <MudGrid Spacing="2">
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label='@Localizer["Home.SearchByCity"]'
                              Value="@_citySearchTerm"
                              ValueChanged="OnCitySearchChanged"
                              Immediate="true"
                              Clearable="true"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" />
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Country?"
                           Label='@Localizer["Home.FilterByCountry"]'
                           Value="@_selectedCountry"
                           ValueChanged="OnCountryChanged"
                           Clearable="true"
                           Variant="Variant.Outlined">
                    @foreach (var country in _countries)
                    {
                        <MudSelectItem T="Country?" Value="@((Country?)country)">
                            @Localizer.LocalizeEnum(country)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="3">
                <MudSelect T="Continent?"
                           Label='@Localizer["Home.FilterByContinent"]'
                           Value="@_selectedContinent"
                           ValueChanged="OnContinentChanged"
                           Clearable="true"
                           Variant="Variant.Outlined">
                    @foreach (var continent in _continents)
                    {
                        <MudSelectItem T="Continent?" Value="@((Continent?)continent)">
                            @Localizer.LocalizeEnum(continent)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           FullWidth="true"
                           OnClick="ClearFiltersAsync">
                    @Localizer["Home.ClearFilters"]
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-4" />
    }

    @if (_cities.Count == 0 && !_isLoading)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            @Localizer["Home.NoCitiesMatch"]
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var city in _cities)
            {
                <MudItem xs="6" sm="4" md="3">
                    <MudCard Elevation="6"
                             Class="city-card vibrant-city-card">
                        @if (_cityImagePaths.TryGetValue(city.Id, out var imgData) && !string.IsNullOrEmpty(imgData))
                        {
                            <img src="@imgData" alt="@city.Name" style="width:100%;height:200px;object-fit:cover;" />
                        }
                        else
                        {
                            <div class="city-card-placeholder">
                                <MudProgressCircular Indeterminate="true" Color="Color.Info" Size="Size.Small" />
                            </div>
                        }

                        <MudCardContent Class="vibrant-city-card-content">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.h6" Class="vibrant-city-card-title">@city.Name</MudText>
                                    <MudText Typo="Typo.body2" Class="city-card-country">@Localizer.LocalizeEnum(city.Country)</MudText>
                                </MudStack>

                                <MudStack Spacing="1" AlignItems="AlignItems.End">
                                    @if (_countryFlagPaths.TryGetValue(city.Country, out var flagData) && !string.IsNullOrEmpty(flagData))
                                    {
                                        <img src="@flagData"
                                             alt='@Localizer["Home.CountryFlagAlt", Localizer.LocalizeEnum(city.Country)]'
                                             class="country-flag-image"
                                             style="width:44px;height:28px;object-fit:cover;" />
                                    }

                                    <MudChip T="string"
                                             Class="vibrant-city-card-continent"
                                             Variant="Variant.Filled"
                                             Size="Size.Small">
                                        @Localizer.LocalizeEnum(city.Continent)
                                    </MudChip>
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions Class="d-flex justify-space-between w-100">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Medium"
                                       OnClick="() => NavigateToQuiz(city.Id)">
                                @Localizer["Home.Quiz"]
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       Size="Size.Medium"
                                       OnClick="() => NavigateToStudy(city.Id)">
                                @Localizer["Home.Study"]
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    [Inject] private ICityService CityService { get; set; } = default!;
    [Inject] private ISyncService SyncService { get; set; } = default!;
    [Inject] private IImageCacheService ImageCache { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private readonly Continent[] _continents = Enum.GetValues<Continent>();
    private readonly Dictionary<int, string> _cityImagePaths = [];
    private readonly Dictionary<Country, string> _countryFlagPaths = [];

    private List<City> _cities = [];
    private List<Country> _countries = [];
    private string _citySearchTerm = string.Empty;
    private Country? _selectedCountry;
    private Continent? _selectedContinent;
    private bool _isLoading;
    private int _totalCityCount;
    private int _totalLandmarkCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await SyncService.SyncCitiesAndMonumentsIfNeededAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }

        var cityCountTask = CityService.GetCityCountAsync();
        var landmarkCountTask = CityService.GetLandmarkCountAsync();
        var countriesTask = CityService.GetCountriesWithCitiesAsync();

        await Task.WhenAll(cityCountTask, landmarkCountTask, countriesTask);

        _totalCityCount = await cityCountTask;
        _totalLandmarkCount = await landmarkCountTask;
        _countries = await countriesTask;

        await LoadCitiesAsync();
    }

    private async Task LoadCitiesAsync()
    {
        _isLoading = true;

        try
        {
            _cities = await CityService.GetCitiesAsync(_citySearchTerm, _selectedCountry, _selectedContinent);
            await LoadCityImagesAsync(_cities);
            await LoadCountryFlagsAsync(_cities);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadCityImagesAsync(IEnumerable<City> cities)
    {
        foreach (var city in cities)
        {
            if (_cityImagePaths.ContainsKey(city.Id))
            {
                continue;
            }

            if (string.IsNullOrWhiteSpace(city.ImagePath))
            {
                _cityImagePaths[city.Id] = string.Empty;
                continue;
            }

            try
            {
                var localPath = await ImageCache.GetImagePathAsync(city.ImagePath);
                _cityImagePaths[city.Id] = ImageHelpers.ConvertToBase64DataUri(localPath);
            }
            catch
            {
                _cityImagePaths[city.Id] = string.Empty;
            }
        }
    }

    private async Task LoadCountryFlagsAsync(IEnumerable<City> cities)
    {
        foreach (var city in cities)
        {
            if (_countryFlagPaths.ContainsKey(city.Country))
            {
                continue;
            }

            try
            {
                var relativePath = GetCountryFlagImagePath(city.Country);
                var localPath = await ImageCache.GetImagePathAsync(relativePath);
                _countryFlagPaths[city.Country] = ImageHelpers.ConvertToBase64DataUri(localPath);
            }
            catch
            {
                _countryFlagPaths[city.Country] = string.Empty;
            }
        }
    }

    private async Task OnCitySearchChanged(string? value)
    {
        _citySearchTerm = value ?? string.Empty;
        await LoadCitiesAsync();
    }

    private async Task OnCountryChanged(Country? value)
    {
        _selectedCountry = value;
        await LoadCitiesAsync();
    }

    private async Task OnContinentChanged(Continent? value)
    {
        _selectedContinent = value;
        await LoadCitiesAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _citySearchTerm = string.Empty;
        _selectedCountry = null;
        _selectedContinent = null;

        await LoadCitiesAsync();
    }

    private static string GetCountryFlagImagePath(Country country) =>
        $"flags/{CityDataHelper.NormalizeForPath(country.ToString())}.png";

    private string FormatCount(int count, string singularKey, string pluralKey) =>
        count == 1
            ? Localizer[singularKey, count].Value
            : Localizer[pluralKey, count].Value;

    private void NavigateToStudy(int cityId) => Navigation.NavigateTo($"study/{cityId}");

    private void NavigateToQuiz(int cityId) => Navigation.NavigateTo($"quiz/{cityId}");
}
