@page "/"
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Services

<MudContainer>
    <MudText Typo="Typo.body1" Class="mb-4">Select a city to start the landmark quiz!</MudText>

    <MudGrid>
        @foreach (var city in _cities)
        {
            <MudItem xs="6" sm="4" md="3">
                <MudCard Elevation="3" 
                    Class="city-card" @onclick="() => NavigateToQuiz(city.Id)" 
                    Style="cursor:pointer;">
                    <MudCardMedia Image="@CityDataHelper.GetCityImagePath(city.Name)" Height="200" />
                    <MudCardContent Class="d-flex justify-center">
                        <MudText Typo="Typo.h6">@city.Name</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Inject] private ICityService CityService { get; set; } = default!;
    [Inject] private ISyncService SyncService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<City> _cities = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await SyncService.SyncCitiesAndMonumentsIfNeededAsync();
        } 
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            // Optionally, show a user-friendly message or log the error to an external service)
        }
        _cities = await CityService.GetCitiesAsync();
    }

    private void NavigateToQuiz(int cityId) => Navigation.NavigateTo($"quiz/{cityId}");
}
