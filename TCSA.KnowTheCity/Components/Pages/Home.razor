@page "/"
@using TCSA.KnowTheCity.Helpers

<MudContainer>
    <MudText Typo="Typo.body1" Class="mb-4">Select a city to start the landmark quiz!</MudText>

    <MudGrid>
        @foreach (var city in CityData.Cities)
        {
            <MudItem xs="6" sm="4" md="3">
                <MudCard Elevation="3" 
                    Class="city-card" @onclick="() => NavigateToQuiz(city.Name)" 
                    Style="cursor:pointer;">
                    <MudCardMedia Image="@CityData.GetCityImagePath(city.Name)" Height="200" />
                    <MudCardContent Class="d-flex justify-center">
                        <MudText Typo="Typo.h6">@city.Name</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private void NavigateToQuiz(string cityName) => Navigation.NavigateTo($"quiz/{cityName}");
}
