@page "/instructions"
@inject IStringLocalizer<SharedResource> Localizer

<MudContainer MaxWidth="MaxWidth.Large" Class="instructions-page pb-8">
    <MudPaper Elevation="0" Class="instructions-hero mb-6">
        <MudStack Spacing="3">
            <MudChip T="string"
                     Class="instructions-hero-chip"
                     Variant="Variant.Filled"
                     Icon="@Icons.Material.Filled.Info">
                @Localizer["Instructions.Tag"]
            </MudChip>

            <MudText Typo="Typo.h4" Class="instructions-hero-title">
                @Localizer["Instructions.Title"]
            </MudText>

            <MudText Typo="Typo.body1" Class="instructions-hero-subtitle">
                @Localizer["Instructions.Subtitle"]
            </MudText>

            <MudStack Row="true" Spacing="2" Class="instructions-hero-actions">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Href="/"
                           StartIcon="@Icons.Material.Filled.Home">
                    @Localizer["Instructions.ChooseCity"]
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           Href="/study"
                           StartIcon="@Icons.Material.Filled.MenuBook">
                    @Localizer["Instructions.StudyFirst"]
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Href="/favorites"
                           StartIcon="@Icons.Material.Filled.Favorite">
                    @Localizer["Instructions.OpenFavorites"]
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="instructions-panel instructions-panel-play h-100">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudPaper Elevation="0" Class="instructions-icon-badge instructions-icon-badge-play">
                            <MudIcon Icon="@Icons.Material.Filled.Quiz" />
                        </MudPaper>

                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6" Class="instructions-panel-title">
                                @Localizer["Instructions.HowToPlay.Title"]
                            </MudText>

                            <MudText Typo="Typo.body2" Class="instructions-panel-subtitle">
                                @Localizer["Instructions.HowToPlay.Subtitle"]
                            </MudText>
                        </MudStack>
                    </MudStack>

                    <ol class="instructions-list">
                        <li>@Localizer["Instructions.HowToPlay.Step1"]</li>
                        <li>@Localizer["Instructions.HowToPlay.Step2"]</li>
                        <li>@Localizer["Instructions.HowToPlay.Step3"]</li>
                        <li>@Localizer["Instructions.HowToPlay.Step4"]</li>
                        <li>@Localizer["Instructions.HowToPlay.Step5"]</li>
                        <li>@Localizer["Instructions.HowToPlay.Step6"]</li>
                    </ol>

                    <MudChip T="string"
                             Class="brand-chip brand-chip-sky"
                             Variant="Variant.Filled">
                        @Localizer["Instructions.HowToPlay.Chip"]
                    </MudChip>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="instructions-panel instructions-panel-search h-100">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudPaper Elevation="0" Class="instructions-icon-badge instructions-icon-badge-search">
                            <MudIcon Icon="@Icons.Material.Filled.Search" />
                        </MudPaper>

                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6" Class="instructions-panel-title">
                                @Localizer["Instructions.UseSearch.Title"]
                            </MudText>

                            <MudText Typo="Typo.body2" Class="instructions-panel-subtitle">
                                @Localizer["Instructions.UseSearch.Subtitle"]
                            </MudText>
                        </MudStack>
                    </MudStack>

                    <ol class="instructions-list">
                        <li>@Localizer["Instructions.UseSearch.Step1"]</li>
                        <li>@Localizer["Instructions.UseSearch.Step2"]</li>
                        <li>@Localizer["Instructions.UseSearch.Step3"]</li>
                        <li>@Localizer["Instructions.UseSearch.Step4"]</li>
                        <li>@Localizer["Instructions.UseSearch.Step5"]</li>
                    </ol>

                    <MudChip T="string"
                             Class="brand-chip brand-chip-gold"
                             Variant="Variant.Filled">
                        @Localizer["Instructions.UseSearch.Chip"]
                    </MudChip>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="instructions-panel instructions-panel-favorites h-100">
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudPaper Elevation="0" Class="instructions-icon-badge instructions-icon-badge-favorites">
                            <MudIcon Icon="@Icons.Material.Filled.Favorite" />
                        </MudPaper>

                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h6" Class="instructions-panel-title">
                                @Localizer["Instructions.Favorites.Title"]
                            </MudText>

                            <MudText Typo="Typo.body2" Class="instructions-panel-subtitle">
                                @Localizer["Instructions.Favorites.Subtitle"]
                            </MudText>
                        </MudStack>
                    </MudStack>

                    <ol class="instructions-list">
                        <li>@Localizer["Instructions.Favorites.Step1"]</li>
                        <li>@Localizer["Instructions.Favorites.Step2"]</li>
                        <li>@Localizer["Instructions.Favorites.Step3"]</li>
                        <li>@Localizer["Instructions.Favorites.Step4"]</li>
                        <li>@Localizer["Instructions.Favorites.Step5"]</li>
                    </ol>

                    <MudChip T="string"
                             Class="brand-chip brand-chip-orange"
                             Variant="Variant.Filled">
                        @Localizer["Instructions.Favorites.Chip"]
                    </MudChip>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="0" Class="instructions-tips-shell">
        <MudText Typo="Typo.h6" Class="instructions-panel-title" GutterBottom="true">
            @Localizer["Instructions.QuickTips.Title"]
        </MudText>

        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="instructions-tip-card h-100">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Class="instructions-tip-icon" />
                            <MudText Typo="Typo.subtitle1" Class="instructions-tip-title">
                                @Localizer["Instructions.QuickTips.NewCity.Title"]
                            </MudText>
                        </MudStack>

                        <MudText Typo="Typo.body2" Class="instructions-tip-text">
                            @Localizer["Instructions.QuickTips.NewCity.Text"]
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="instructions-tip-card h-100">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Timer" Class="instructions-tip-icon" />
                            <MudText Typo="Typo.subtitle1" Class="instructions-tip-title">
                                @Localizer["Instructions.QuickTips.Timer.Title"]
                            </MudText>
                        </MudStack>

                        <MudText Typo="Typo.body2" Class="instructions-tip-text">
                            @Localizer["Instructions.QuickTips.Timer.Text"]
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="instructions-tip-card h-100">
                    <MudStack Spacing="2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Replay" Class="instructions-tip-icon" />
                            <MudText Typo="Typo.subtitle1" Class="instructions-tip-title">
                                @Localizer["Instructions.QuickTips.Practice.Title"]
                            </MudText>
                        </MudStack>

                        <MudText Typo="Typo.body2" Class="instructions-tip-text">
                            @Localizer["Instructions.QuickTips.Practice.Text"]
                        </MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>