@page "/quiz/favorites"
@page "/quiz/{CityId:int}"
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Core.Services
@using TCSA.KnowTheCity.Services
@inject IStringLocalizer<SharedResource> Localizer
@implements IAsyncDisposable

@if (_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="quiz-shell-container">
        <MudPaper Elevation="6" Class="quiz-loading-shell py-10 px-6 rounded-xl" Style="width:75%;margin:0 auto;">
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.h6">@Localizer["Quiz.LoadingImages", _imagesLoaded, _quizLandmarks.Count]</MudText>
            </MudStack>
        </MudPaper>
    </MudContainer>
}
else if (!_quizFinished && _quizLandmarks.Count > 0 && _currentIndex < _quizLandmarks.Count)
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="quiz-shell-container">
        <MudPaper Elevation="8" Class="quiz-shell py-4 px-6 rounded-xl overflow-hidden" Style="width:75%;margin:0 auto;">
            <div class="quiz-image-frame mb-4" Style="@GetQuizImageFrameStyle()">
                @{
                    var key = GetImageCacheKey(CurrentLandmark);
                    _cachedImagePaths.TryGetValue(key, out var desktopImgData);
                    _cachedMobileImagePaths.TryGetValue(key, out var mobileImgData);

                    var hasDesktop = !string.IsNullOrEmpty(desktopImgData);
                    var hasMobile = !string.IsNullOrEmpty(mobileImgData);
                    var fallbackImg = hasDesktop ? desktopImgData : mobileImgData;
                }

                @if (!string.IsNullOrEmpty(fallbackImg))
                {
                    <picture>
                        @if (hasMobile)
                        {
                            <source media="(orientation: portrait)" srcset="@mobileImgData" />
                        }
                        <img src="@fallbackImg" alt='@Localizer["Quiz.ImageAlt"]' class="quiz-image" />
                    </picture>
                }
                else
                {
                    <div class="quiz-image-placeholder">
                        <MudProgressCircular Indeterminate="true" Color="Color.Info" Size="Size.Small" />
                    </div>
                }
            </div>

            @if (!_isAnswered)
            {
                <MudTextField @bind-Value="_currentGuess"
                              Label='@Localizer["Quiz.NameThisLandmark"]'
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Class="mb-4"
                              OnKeyDown="HandleKeyDown" />

                <MudGrid Class="mb-3">
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Class="quiz-action-button"
                                   OnClick="SubmitGuess">
                            @Localizer["Quiz.Answer"]
                        </MudButton>
                    </MudItem>
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Warning"
                                   FullWidth="true"
                                   Class="quiz-action-button"
                                   OnClick="SkipLandmark">
                            @Localizer["Quiz.Skip"]
                        </MudButton>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudAlert Severity="@_feedbackSeverity"
                          Variant="Variant.Filled"
                          Dense="true"
                          Class="mb-4">
                    @_feedbackMessage
                </MudAlert>

                <MudButton Variant="Variant.Filled"
                           Color="@(IsLastLandmark ? Color.Success : Color.Primary)"
                           FullWidth="true"
                           Class="quiz-action-button mb-3"
                           OnClick="MoveToNextAsync">
                    @(IsLastLandmark ? "Finish" : "Next")
                </MudButton>
            }
        </MudPaper>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="quiz-shell-container">
        <MudPaper Elevation="6" Class="quiz-loading-shell py-10 px-6 rounded-xl" Style="width:75%;margin:0 auto;">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Quiz" Color="Color.Info" Size="Size.Large" />
                <MudText Typo="Typo.h6">@Localizer["Quiz.NoLandmarksTitle"]</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center">
                    @(IsFavoritesQuiz
                        ? Localizer["Quiz.NoLandmarksFavoritesText"]
                        : Localizer["Quiz.NoLandmarksCityText"])
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="NavigateBack">
                    @(IsFavoritesQuiz ? Localizer["Quiz.BackToFavorites"] : Localizer["Quiz.BackToHome"])
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudContainer>
}

@code {
    [Parameter]
    public int? CityId { get; set; }

    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private IFavoriteService FavoriteService { get; set; } = default!;

    [Inject]
    private ICityService CityService { get; set; } = default!;

    [Inject]
    private IImageCacheService ImageCacheService { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private List<QuizLandmarkItem> _quizLandmarks = [];
    private List<GameResultItem> _results = [];
    private Dictionary<string, string> _cachedImagePaths = [];
    private Dictionary<string, string> _cachedMobileImagePaths = [];
    private string _quizTitle = string.Empty;
    private int _resultCityId;
    private int _currentIndex;
    private int _correctCount;
    private string _currentGuess = string.Empty;
    private string _feedbackMessage = string.Empty;
    private Severity _feedbackSeverity = Severity.Info;
    private bool _quizFinished;
    private bool _isLoading = true;
    private int _imagesLoaded;
    private CancellationTokenSource _cts = new();

    private bool IsFavoritesQuiz => !CityId.HasValue;

    private QuizLandmarkItem CurrentLandmark => _quizLandmarks[_currentIndex];

    private bool _isAnswered;
    private bool IsLastLandmark => _quizLandmarks.Count > 0 && _currentIndex == _quizLandmarks.Count - 1;

    protected override async Task OnParametersSetAsync()
    {
        await ResetQuizStateAsync();
        await LoadQuizAsync();
    }

    private async Task ResetQuizStateAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();

        _cts = new();
        _quizLandmarks = [];
        _results = [];
        _cachedImagePaths = [];
        _cachedMobileImagePaths = [];
        _quizTitle = string.Empty;
        _resultCityId = 0;
        _currentIndex = 0;
        _correctCount = 0;
        _currentGuess = string.Empty;
        _feedbackMessage = string.Empty;
        _feedbackSeverity = Severity.Info;
        _quizFinished = false;
        _isLoading = true;
        _imagesLoaded = 0;
        _isAnswered = false;
    }

    private async Task LoadQuizAsync()
    {
        var cities = await CityService.GetCitiesAsync();
        var citiesById = cities.ToDictionary(c => c.Id);

        if (CityId.HasValue)
        {
            var city = citiesById.GetValueOrDefault(CityId.Value) ?? await CityService.GetCityByIdAsync(CityId.Value);
            if (city is null)
            {
                _isLoading = false;
                return;
            }

            var localizedCityName = city.GetLocalizedName();
            _quizTitle = localizedCityName;
            _resultCityId = city.Id;

            var landmarks = await CityService.GetLandmarksAsync(city.RemoteId);
            _quizLandmarks =
            [
                .. landmarks
                .Select(landmark => new QuizLandmarkItem(city.Id, localizedCityName, landmark))
                .OrderBy(_ => Random.Shared.Next())
            ];
        }
        else
        {
            _quizTitle = Localizer["Quiz.FavoritesTitle"].Value;

            var favoriteLandmarks = await FavoriteService.GetFavoriteLandmarksAsync();
            _quizLandmarks =
            [
                .. favoriteLandmarks
                .Select(favorite => new QuizLandmarkItem(
                    favorite.CityId,
                    citiesById.TryGetValue(favorite.CityId, out var city)
                        ? city.GetLocalizedName()
                        : favorite.CityId.ToString(),
                    favorite.Landmark))
                .OrderBy(_ => Random.Shared.Next())
            ];

            _resultCityId = _quizLandmarks.FirstOrDefault()?.CityId ?? 0;
        }

        if (_quizLandmarks.Count > 0)
        {
            await CacheAllImagesAsync();
        }

        _isLoading = false;
    }

    private async Task CacheAllImagesAsync()
    {
        foreach (var landmark in _quizLandmarks)
        {
            var key = GetImageCacheKey(landmark);

            try
            {
                _cachedImagePaths[key] = await CacheImageVariantAsync(landmark.Landmark.ImagePath, landmark.Landmark.Name, "desktop");
                _cachedMobileImagePaths[key] = await CacheImageVariantAsync(landmark.Landmark.MobileImagePath, landmark.Landmark.Name, "mobile");
            }
            catch (OperationCanceledException)
            {
                return;
            }

            _imagesLoaded++;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<string> CacheImageVariantAsync(string? imagePath, string landmarkName, string variant)
    {
        if (string.IsNullOrWhiteSpace(imagePath))
        {
            return string.Empty;
        }

        try
        {
            var localPath = await ImageCacheService.GetImagePathAsync(imagePath, _cts.Token);
            return ImageHelpers.ConvertToBase64DataUri(localPath);
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Quiz] Failed to cache {variant} image for {landmarkName}: {ex.Message}");
            return string.Empty;
        }
    }

    private static string GetImageCacheKey(QuizLandmarkItem landmark)
    {
        return $"{landmark.CityId}:{landmark.Landmark.Id}";
    }

    private async void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
            return;

        if (_isAnswered)
        {
            await MoveToNextAsync();
            return;
        }

        await SubmitGuess();
    }

    private async Task SubmitGuess()
    {
        if (string.IsNullOrWhiteSpace(_currentGuess) || _quizFinished || _isAnswered)
            return;

        var expected = CurrentLandmark;
        var trimmedGuess = _currentGuess.Trim();
        var isCorrect = IsMatchingLandmarkName(expected.Landmark, trimmedGuess);
        var localizedLandmarkName = expected.Landmark.GetLocalizedName();

        if (isCorrect)
        {
            _results.Add(new() { LandmarkId = expected.Landmark.Id, IsCorrect = true });
            _correctCount++;
            _feedbackMessage = IsFavoritesQuiz
                ? Localizer["Quiz.Feedback.CorrectWithCity", localizedLandmarkName, expected.CityName].Value
                : Localizer["Quiz.Feedback.Correct", localizedLandmarkName].Value;
            _feedbackSeverity = Severity.Success; // green
        }
        else
        {
            _results.Add(new()
            {
                LandmarkId = expected.Landmark.Id,
                IsCorrect = false,
                Label = BuildResultLabel("Quiz.ResultLabel.WrongAnswer", expected)
            });

            _feedbackMessage = IsFavoritesQuiz
                ? Localizer["Quiz.Feedback.WrongWithCity", localizedLandmarkName, expected.CityName].Value
                : Localizer["Quiz.Feedback.Wrong", localizedLandmarkName].Value;
            _feedbackSeverity = Severity.Error;
        }

        _currentGuess = string.Empty;
        _isAnswered = true;

        await Task.CompletedTask;
    }

    private async Task SkipLandmark()
    {
        if (_quizFinished || _isAnswered)
            return;

        var expected = CurrentLandmark;
        var localizedLandmarkName = expected.Landmark.GetLocalizedName();

        _results.Add(new()
        {
            LandmarkId = expected.Landmark.Id,
            IsCorrect = false,
            Label = BuildResultLabel("Quiz.ResultLabel.Skipped", expected)
        });

        _feedbackMessage = IsFavoritesQuiz
            ? Localizer["Quiz.Feedback.SkippedWithCity", localizedLandmarkName, expected.CityName].Value
            : Localizer["Quiz.Feedback.Skipped", localizedLandmarkName].Value;
        _feedbackSeverity = Severity.Error;
        _currentGuess = string.Empty;
        _isAnswered = true;

        await Task.CompletedTask;
    }

    private async Task MoveToNextAsync()
    {
        if (_quizFinished || !_isAnswered)
            return;

        if (IsLastLandmark)
        {
            await FinishQuizAsync();
            return;
        }

        _currentIndex++;
        ResetCurrentQuestionState();
    }

    private void ResetCurrentQuestionState()
    {
        _currentGuess = string.Empty;
        _feedbackMessage = string.Empty;
        _feedbackSeverity = Severity.Info;
        _isAnswered = false;
    }

    private async Task FinishQuizAsync()
    {
        if (_quizFinished)
            return;

        _quizFinished = true;

        for (var i = _results.Count; i < _quizLandmarks.Count; i++)
        {
            _results.Add(new()
            {
                LandmarkId = _quizLandmarks[i].Landmark.Id,
                IsCorrect = false,
                Label = BuildResultLabel("Quiz.ResultLabel.TimedOut", _quizLandmarks[i])
            });
        }

        if (_resultCityId == 0)
        {
            Navigation.NavigateTo("/favorites");
            return;
        }

        var gameResult = new GameResult
        {
            CityId = CityId ?? _resultCityId,
            CorrectCount = _correctCount,
            TotalCount = _quizLandmarks.Count,
            PlayedAt = DateTime.Now,
            Items = _results
        };

        var id = await GameService.SaveGameResultAsync(gameResult);
        Navigation.NavigateTo($"/results/{id}");
    }

    private string BuildResultLabel(string labelKey, QuizLandmarkItem landmark)
    {
        return IsFavoritesQuiz
            ? $"{labelKey}|{landmark.CityName}"
            : labelKey;
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo(IsFavoritesQuiz ? "/favorites" : "/");
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
    }

    private static bool IsMatchingLandmarkName(Landmark landmark, string guess)
    {
        if (string.Equals(landmark.Name, guess, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        if (landmark.Translations is null || landmark.Translations.Count == 0)
        {
            return false;
        }

        foreach (var translation in landmark.Translations)
        {
            if (!string.IsNullOrWhiteSpace(translation?.Name)
                && string.Equals(translation.Name, guess, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        return false;
    }

    private string? GetQuizImageFrameStyle()
    {
        if (!_isAnswered)
        {
            return null;
        }

        // Requested mapping:
        // Correct => red, Wrong/Skipped => green
        return _feedbackSeverity == Severity.Success
            ? "border-color:#2e7d32 !important; box-shadow:0 0 0 2px rgba(46,125,50,.35), 0 14px 28px rgba(17,20,95,.12);"
            : "border-color:#e84a1c !important; box-shadow:0 0 0 2px rgba(232,74,28,.35), 0 14px 28px rgba(17,20,95,.12);";
    }

    private sealed record QuizLandmarkItem(int CityId, string CityName, Landmark Landmark);
}