@page "/quiz/favorites"
@page "/quiz/{CityId:int}"
@using System.Timers
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Core.Services
@using TCSA.KnowTheCity.Services
@implements IAsyncDisposable

@if (_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper Elevation="6" Class="quiz-loading-shell py-10 px-6 rounded-xl">
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                <MudProgressCircular Color="Color.Info" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.h6">Loading images… @_imagesLoaded / @_quizLandmarks.Count</MudText>
            </MudStack>
        </MudPaper>
    </MudContainer>
}
else if (!_quizFinished && _quizLandmarks.Count > 0 && _currentIndex < _quizLandmarks.Count)
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper Elevation="8" Class="quiz-shell py-4 px-6 rounded-xl overflow-hidden">
            <MudStack Spacing="3" Class="mb-3">
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudChip T="string"
                             Class="quiz-city-chip"
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        @_quizTitle
                    </MudChip>

                    @if (IsFavoritesQuiz)
                    {
                        <MudChip T="string"
                                 Class="quiz-city-chip"
                                 Variant="Variant.Filled"
                                 Size="Size.Large">
                            @CurrentLandmark.CityName
                        </MudChip>
                    }

                    <MudChip T="string"
                             Class="quiz-stage-chip"
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        Quiz @(_currentIndex + 1)/@_quizLandmarks.Count
                    </MudChip>

                    <MudChip T="string"
                             Class="quiz-score-chip"
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        Score: @_correctCount
                    </MudChip>

                    <MudChip T="string"
                             Class="@(_timeRemaining <= 10 ? "quiz-timer-chip-danger" : "quiz-timer-chip")"
                             Variant="Variant.Filled"
                             Icon="@Icons.Material.Filled.Timer"
                             Size="Size.Large">
                        @TimeSpan.FromSeconds(_timeRemaining).ToString("m\\:ss")
                    </MudChip>
                </MudStack>

                @if (!string.IsNullOrEmpty(_feedbackMessage))
                {
                    <MudAlert Severity="@_feedbackSeverity" Variant="Variant.Filled" Dense="true">
                        @_feedbackMessage
                    </MudAlert>
                }
            </MudStack>

            <MudProgressLinear Color="@(_timeRemaining <= 10 ? Color.Error : Color.Primary)"
                               Value="@((_timeRemaining / 60.0) * 100)"
                               Class="@(_timeRemaining <= 10 ? "mb-4 quiz-progress-danger" : "mb-4 quiz-progress")"
                               Rounded="true"
                               Size="Size.Large" />

            <MudPaper Elevation="0" Class="quiz-question-banner pa-4 mb-4">
                <MudText Typo="Typo.subtitle2" Class="quiz-question-subtitle">
                    Landmark @(_currentIndex + 1) of @_quizLandmarks.Count
                </MudText>
                <MudText Typo="Typo.h5" Class="quiz-question-title">
                    Can you name this landmark?
                </MudText>
            </MudPaper>

            <div class="quiz-image-frame mb-4">
                @if (_cachedImagePaths.TryGetValue(GetImageCacheKey(CurrentLandmark), out var imgData) && !string.IsNullOrEmpty(imgData))
                {
                    <img src="@imgData" alt="Landmark" style="width:100%;height:400px;object-fit:cover;" />
                }
                else
                {
                    <div class="quiz-image-placeholder">
                        <MudProgressCircular Indeterminate="true" Color="Color.Info" Size="Size.Small" />
                    </div>
                }
            </div>

            <MudTextField @bind-Value="_currentGuess"
                          Label="Name this landmark..."
                          Variant="Variant.Outlined"
                          Immediate="true"
                          Class="mb-4"
                          OnKeyDown="HandleKeyDown" />

            <MudGrid Class="mb-3">
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Class="quiz-action-button"
                               OnClick="SubmitGuess">
                        Answer
                    </MudButton>
                </MudItem>
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Warning"
                               FullWidth="true"
                               Class="quiz-action-button"
                               OnClick="SkipLandmark">
                        Skip
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper Elevation="6" Class="quiz-loading-shell py-10 px-6 rounded-xl">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Quiz" Color="Color.Info" Size="Size.Large" />
                <MudText Typo="Typo.h6">No landmarks available for this quiz.</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center">
                    @(IsFavoritesQuiz
                        ? "Save at least one favourite landmark, then start the favourites quiz again."
                        : "This city does not have any landmarks available yet.")
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="NavigateBack">
                    @(IsFavoritesQuiz ? "Back to favourites" : "Back to home")
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudContainer>
}

@code {
    [Parameter]
    public int? CityId { get; set; }

    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private IFavoriteService FavoriteService { get; set; } = default!;

    [Inject]
    private ICityService CityService { get; set; } = default!;

    [Inject]
    private IImageCacheService ImageCacheService { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private List<QuizLandmarkItem> _quizLandmarks = [];
    private List<GameResultItem> _results = [];
    private Dictionary<string, string> _cachedImagePaths = [];
    private string _quizTitle = string.Empty;
    private int _resultCityId;
    private int _currentIndex;
    private int _correctCount;
    private string _currentGuess = string.Empty;
    private string _feedbackMessage = string.Empty;
    private Severity _feedbackSeverity = Severity.Info;
    private int _timeRemaining = 60;
    private bool _quizFinished;
    private bool _isLoading = true;
    private int _imagesLoaded;
    private Timer? _timer;
    private CancellationTokenSource _cts = new();

    private bool IsFavoritesQuiz => !CityId.HasValue;

    private QuizLandmarkItem CurrentLandmark => _quizLandmarks[_currentIndex];

    protected override async Task OnParametersSetAsync()
    {
        await ResetQuizStateAsync();
        await LoadQuizAsync();
    }

    private async Task ResetQuizStateAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();

        _timer?.Stop();
        _timer?.Dispose();

        _cts = new();
        _quizLandmarks = [];
        _results = [];
        _cachedImagePaths = [];
        _quizTitle = string.Empty;
        _resultCityId = 0;
        _currentIndex = 0;
        _correctCount = 0;
        _currentGuess = string.Empty;
        _feedbackMessage = string.Empty;
        _feedbackSeverity = Severity.Info;
        _timeRemaining = 60;
        _quizFinished = false;
        _isLoading = true;
        _imagesLoaded = 0;
    }

    private async Task LoadQuizAsync()
    {
        var cities = await CityService.GetCitiesAsync();
        var citiesById = cities.ToDictionary(c => c.Id);

        if (CityId.HasValue)
        {
            var city = citiesById.GetValueOrDefault(CityId.Value) ?? await CityService.GetCityByIdAsync(CityId.Value);
            if (city is null)
            {
                _isLoading = false;
                return;
            }

            _quizTitle = city.Name;
            _resultCityId = city.Id;

            var landmarks = await CityService.GetLandmarksAsync(city.RemoteId);
            _quizLandmarks =
            [
                .. landmarks
                    .Select(landmark => new QuizLandmarkItem(city.Id, city.Name, landmark))
                    .OrderBy(_ => Random.Shared.Next())
            ];
        }
        else
        {
            _quizTitle = "Favourite landmarks";

            var favoriteLandmarks = await FavoriteService.GetFavoriteLandmarksAsync();
            _quizLandmarks =
            [
                .. favoriteLandmarks
                    .Select(favorite => new QuizLandmarkItem(
                        favorite.CityId,
                        citiesById.TryGetValue(favorite.CityId, out var city) ? city.Name : favorite.CityId.ToString(),
                        favorite.Landmark))
                    .OrderBy(_ => Random.Shared.Next())
            ];

            _resultCityId = _quizLandmarks.FirstOrDefault()?.CityId ?? 0;
        }

        if (_quizLandmarks.Count > 0)
        {
            await CacheAllImagesAsync();
            StartTimer();
        }

        _isLoading = false;
    }

    private void StartTimer()
    {
        _timer = new Timer(1000);
        _timer.Elapsed += OnTimerElapsed;
        _timer.Start();
    }

    private async Task CacheAllImagesAsync()
    {
        foreach (var landmark in _quizLandmarks)
        {
            var imagePath = landmark.Landmark.ImagePath;

            if (string.IsNullOrWhiteSpace(imagePath))
            {
                _cachedImagePaths[GetImageCacheKey(landmark)] = string.Empty;
                _imagesLoaded++;
                await InvokeAsync(StateHasChanged);
                continue;
            }

            try
            {
                var localPath = await ImageCacheService.GetImagePathAsync(imagePath, _cts.Token);
                _cachedImagePaths[GetImageCacheKey(landmark)] = ImageHelpers.ConvertToBase64DataUri(localPath);
            }
            catch (OperationCanceledException)
            {
                return;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Quiz] Failed to cache image for {landmark.Landmark.Name}: {ex.Message}");
                _cachedImagePaths[GetImageCacheKey(landmark)] = string.Empty;
            }

            _imagesLoaded++;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetImageCacheKey(QuizLandmarkItem landmark)
    {
        return $"{landmark.CityId}:{landmark.Landmark.Id}";
    }

    private async void OnTimerElapsed(object? sender, ElapsedEventArgs e)
    {
        if (_quizFinished)
            return;

        _timeRemaining--;

        if (_timeRemaining <= 0)
            await InvokeAsync(FinishQuizAsync);
        else
            await InvokeAsync(StateHasChanged);
    }

    private async void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SubmitGuess();
    }

    private async Task SubmitGuess()
    {
        if (string.IsNullOrWhiteSpace(_currentGuess) || _quizFinished)
            return;

        var expected = CurrentLandmark;
        var isCorrect = string.Equals(expected.Landmark.Name, _currentGuess.Trim(), StringComparison.OrdinalIgnoreCase);

        if (isCorrect)
        {
            _results.Add(new() { LandmarkId = expected.Landmark.Id, IsCorrect = true });
            _correctCount++;
            _feedbackMessage = IsFavoritesQuiz
                ? $"Correct! {expected.Landmark.Name} in {expected.CityName}"
                : $"Correct! {expected.Landmark.Name}";
            _feedbackSeverity = Severity.Success;
        }
        else
        {
            _results.Add(new()
            {
                LandmarkId = expected.Landmark.Id,
                IsCorrect = false,
                Label = BuildResultLabel("wrong answer", expected)
            });

            _feedbackMessage = IsFavoritesQuiz
                ? $"Wrong! The answer was: {expected.Landmark.Name} in {expected.CityName}"
                : $"Wrong! The answer was: {expected.Landmark.Name}";
            _feedbackSeverity = Severity.Error;
        }

        _currentGuess = string.Empty;
        await MoveToNextAsync();
    }

    private async Task SkipLandmark()
    {
        var expected = CurrentLandmark;

        _results.Add(new()
        {
            LandmarkId = expected.Landmark.Id,
            IsCorrect = false,
            Label = BuildResultLabel("skipped", expected)
        });

        _feedbackMessage = IsFavoritesQuiz
            ? $"The answer was: {expected.Landmark.Name} in {expected.CityName}"
            : $"The answer was: {expected.Landmark.Name}";
        _feedbackSeverity = Severity.Error;
        _currentGuess = string.Empty;

        await MoveToNextAsync();
    }

    private async Task MoveToNextAsync()
    {
        _currentIndex++;

        if (_currentIndex >= _quizLandmarks.Count)
            await FinishQuizAsync();
    }

    private async Task FinishQuizAsync()
    {
        if (_quizFinished)
            return;

        _quizFinished = true;
        _timer?.Stop();

        for (var i = _results.Count; i < _quizLandmarks.Count; i++)
        {
            _results.Add(new()
            {
                LandmarkId = _quizLandmarks[i].Landmark.Id,
                IsCorrect = false,
                Label = BuildResultLabel("timed out", _quizLandmarks[i])
            });
        }

        if (_resultCityId == 0)
        {
            Navigation.NavigateTo("/favorites");
            return;
        }

        var gameResult = new GameResult
        {
            CityId = CityId ?? _resultCityId,
            CorrectCount = _correctCount,
            TotalCount = _quizLandmarks.Count,
            PlayedAt = DateTime.Now,
            Items = _results
        };

        var id = await GameService.SaveGameResultAsync(gameResult);
        Navigation.NavigateTo($"/results/{id}");
    }

    private string BuildResultLabel(string label, QuizLandmarkItem landmark)
    {
        return IsFavoritesQuiz
            ? $"{label} • {landmark.CityName}"
            : label;
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo(IsFavoritesQuiz ? "/favorites" : "/");
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _timer?.Stop();
        _timer?.Dispose();
    }

    private sealed record QuizLandmarkItem(int CityId, string CityName, Landmark Landmark);
}