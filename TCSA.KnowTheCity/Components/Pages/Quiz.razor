@page "/quiz/{CityName}"
@using System.Timers
@using TCSA.KnowTheCity.Helpers
@using TCSA.KnowTheCity.Models
@using TCSA.KnowTheCity.Services
@implements IDisposable

@if (!quizFinished && landmarks.Count > 0 && currentIndex < landmarks.Count)
{
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">@CityName</MudText>

        <MudText Typo="Typo.h3" Align="Align.Center"
                 Color="@(timeRemaining <= 10 ? Color.Error : Color.Default)"
                 Class="mb-2"
                 Style="@(timeRemaining <= 10 ? "animation: pulse 1s infinite;" : "")">
            ?? @timeRemaining s
        </MudText>

        <MudProgressLinear Color="@(timeRemaining <= 10 ? Color.Error : Color.Primary)"
                           Value="@((timeRemaining / 60.0) * 100)"
                           Class="mb-4" Rounded="true" Size="Size.Large" />

        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">
            Landmark @(currentIndex + 1) of @landmarks.Count
        </MudText>

        <MudCard Elevation="2" Class="mb-4">
            <MudCardMedia Image="@CityData.GetLandmarkImagePath(CityName, landmarks[currentIndex])" Height="620" />
        </MudCard>

        <MudGrid Class="mb-3">
            <MudItem xs="9">
                <MudTextField @bind-Value="currentGuess"
                              Label="Name this landmark..."
                              Variant="Variant.Outlined"
                              Immediate="true"
                              OnKeyDown="HandleKeyDown" />
            </MudItem>
            <MudItem xs="3" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true" OnClick="SubmitGuess"
                           Style="height:56px;">
                    Submit
                </MudButton>
            </MudItem>
        </MudGrid>

        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                   FullWidth="true" OnClick="SkipLandmark"
                   StartIcon="@Icons.Material.Filled.SkipNext"
                   Class="mb-3">
            I Don't Know
        </MudButton>

        @if (!string.IsNullOrEmpty(feedbackMessage))
        {
            <MudAlert Severity="@feedbackSeverity" Class="mb-3" Variant="Variant.Filled" Dense="true">
                @feedbackMessage
            </MudAlert>
        }
    </MudContainer>
}

@code {
    [Parameter]
    public string CityName { get; set; } = "";

    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private List<string> landmarks = [];
    private List<GameResultItem> results = [];
    private int currentIndex;
    private int correctCount;
    private string currentGuess = "";
    private string feedbackMessage = "";
    private Severity feedbackSeverity = Severity.Info;
    private int timeRemaining = 60;
    private bool quizFinished;
    private Timer? timer;

    protected override void OnInitialized()
    {
        landmarks = CityData.GetLandmarks(CityName);

        timer = new Timer(1000);
        timer.Elapsed += OnTimerElapsed;
        timer.Start();
    }

    private async void OnTimerElapsed(object? sender, ElapsedEventArgs e)
    {
        if (quizFinished)
            return;

        timeRemaining--;

        if (timeRemaining <= 0)
        {
            await InvokeAsync(FinishQuizAsync);
        }
        else
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            SubmitGuess();
        }
    }

    private async void SubmitGuess()
    {
        if (string.IsNullOrWhiteSpace(currentGuess) || quizFinished)
            return;

        var expected = landmarks[currentIndex];
        var isCorrect = string.Equals(expected, currentGuess.Trim(), StringComparison.OrdinalIgnoreCase);

        if (isCorrect)
        {
            results.Add(new() { Landmark = expected, IsCorrect = true });
            correctCount++;
            feedbackMessage = $"Correct! {expected}";
            feedbackSeverity = Severity.Success;
        }
        else
        {
            results.Add(new() { Landmark = expected, IsCorrect = false, Label = "wrong answer" });
            feedbackMessage = $"Wrong! The answer was: {expected}";
            feedbackSeverity = Severity.Error;
        }

        currentGuess = "";
        await MoveToNextAsync();
    }

    private async void SkipLandmark()
    {
        var expected = landmarks[currentIndex];
        results.Add(new() { Landmark = expected, IsCorrect = false, Label = "skipped" });
        feedbackMessage = $"The answer was: {expected}";
        feedbackSeverity = Severity.Warning;
        currentGuess = "";
        await MoveToNextAsync();
    }

    private async Task MoveToNextAsync()
    {
        currentIndex++;

        if (currentIndex >= landmarks.Count)
        {
            await FinishQuizAsync();
        }
    }

    private async Task FinishQuizAsync()
    {
        if (quizFinished)
            return;

        quizFinished = true;
        timer?.Stop();

        for (var i = results.Count; i < landmarks.Count; i++)
        {
            results.Add(new() { Landmark = landmarks[i], IsCorrect = false, Label = "timed out" });
        }

        var gameResult = new GameResult
        {
            City = CityName,
            CorrectCount = correctCount,
            TotalCount = landmarks.Count,
            PlayedAt = DateTime.Now,
            Items = results
        };

        var id = await GameService.SaveGameResultAsync(gameResult);
        Navigation.NavigateTo($"/results/{id}");
    }

    public void Dispose()
    {
        timer?.Stop();
        timer?.Dispose();
    }
}