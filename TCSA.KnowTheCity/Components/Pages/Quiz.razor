@page "/quiz/{CityName}"
@using System.Timers
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Models
@using TCSA.KnowTheCity.Services
@implements IAsyncDisposable

@if (!quizFinished && landmarks.Count > 0 && currentIndex < landmarks.Count)
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper 
            Elevation="6" 
            Class="py-4 px-20 rounded-xl overflow-hidden">              

            <MudStack AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudStack Row="true" Spacing="5" AlignItems="AlignItems.Center">
                    <MudChip T="string" 
                             Color="Color.Success" 
                             Variant="Variant.Filled" 
                             Size="Size.Large">
                        Quiz @(currentIndex + 1)/@landmarks.Count
                    </MudChip>
                    <MudChip T="string"
                             Color="@(timeRemaining <= 10 ? Color.Error : Color.Warning)"
                             Variant="Variant.Filled"
                             Icon="@Icons.Material.Filled.Timer"
                             Size="Size.Large">
                        @TimeSpan.FromSeconds(timeRemaining).ToString("m\\:ss")
                    </MudChip>
                    <MudChip T="string" 
                             Color="Color.Secondary" 
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        Score: @correctCount
                    </MudChip>
                    @if (!string.IsNullOrEmpty(feedbackMessage))
                    {
                        <MudAlert Severity="@feedbackSeverity" Variant="Variant.Filled" NoIcon Dense="true">
                            @feedbackMessage
                        </MudAlert>
                    }
                </MudStack>
            </MudStack>

        <MudProgressLinear Color="@(timeRemaining <= 10 ? Color.Error : Color.Primary)"
                           Value="@((timeRemaining / 60.0) * 100)"
                           Class="mb-4" Rounded="true" Size="Size.Large" />

        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">
            Landmark @(currentIndex + 1) of @landmarks.Count
        </MudText>

            <div style="border-radius:16px; overflow:hidden;">
                <MudCardMedia Image="@CityDataHelper.GetLandmarkImagePath(CityName, landmarks[currentIndex])"
                              Height="400" />
            </div>

            <MudTextField @bind-Value="currentGuess"
                          Label="Name this landmark..."
                          Variant="Variant.Outlined"
                          Immediate="true"
                          OnKeyDown="HandleKeyDown" />

            <MudGrid Class="mb-3">
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true" OnClick="SubmitGuess"
                               Style="height:56px;">
                        Answer
                    </MudButton>
                </MudItem>
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                               FullWidth="true" OnClick="SkipLandmark"
                               Style="height:56px;">
                        Skip
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
}

@code {
    [Parameter]
    public string CityName { get; set; } = string.Empty;

    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private List<string> landmarks = [];
    private List<GameResultItem> results = [];
    private int currentIndex;
    private int correctCount;
    private string currentGuess = string.Empty;
    private string feedbackMessage = string.Empty;
    private Severity feedbackSeverity = Severity.Info;
    private int timeRemaining = 60;
    private bool quizFinished;
    private Timer? timer;

    protected override void OnInitialized()
    {
        landmarks = CityDataHelper.GetLandmarks(CityName);
        landmarks = [.. landmarks.OrderBy(_ => Random.Shared.Next())];

        timer = new Timer(1000);
        timer.Elapsed += OnTimerElapsed;
        timer.Start();
    }

    private async void OnTimerElapsed(object? sender, ElapsedEventArgs e)
    {
        if (quizFinished)
            return;

        timeRemaining--;

        if (timeRemaining <= 0)
        {
            await InvokeAsync(FinishQuizAsync);
        }
        else
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitGuess();
        }
    }

    private async Task SubmitGuess()
    {
        if (string.IsNullOrWhiteSpace(currentGuess) || quizFinished)
            return;

        var expected = landmarks[currentIndex];
        var isCorrect = string.Equals(expected, currentGuess.Trim(), StringComparison.OrdinalIgnoreCase);

        if (isCorrect)
        {
            results.Add(new() { Landmark = expected, IsCorrect = true });
            correctCount++;
            feedbackMessage = $"Correct! {expected}";
            feedbackSeverity = Severity.Success;
        }
        else
        {
            results.Add(new() { Landmark = expected, IsCorrect = false, Label = "wrong answer" });
            feedbackMessage = $"Wrong! The answer was: {expected}";
            feedbackSeverity = Severity.Error;
        }

        currentGuess = "";
        await MoveToNextAsync();
    }

    private async Task SkipLandmark()
    {
        var expected = landmarks[currentIndex];
        results.Add(new() { Landmark = expected, IsCorrect = false, Label = "skipped" });
        feedbackMessage = $"The answer was: {expected}";
        feedbackSeverity = Severity.Error;
        currentGuess = string.Empty;
        await MoveToNextAsync();
    }

    private async Task MoveToNextAsync()
    {
        currentIndex++;

        if (currentIndex >= landmarks.Count)
        {
            await FinishQuizAsync();
        }
    }

    private async Task FinishQuizAsync()
    {
        if (quizFinished)
            return;

        quizFinished = true;
        timer?.Stop();

        for (var i = results.Count; i < landmarks.Count; i++)
        {
            results.Add(new() { Landmark = landmarks[i], IsCorrect = false, Label = "timed out" });
        }

        var gameResult = new GameResult
        {
            City = CityName,
            CorrectCount = correctCount,
            TotalCount = landmarks.Count,
            PlayedAt = DateTime.Now,
            Items = results
        };

        var id = await GameService.SaveGameResultAsync(gameResult);
        Navigation.NavigateTo($"/results/{id}");
    }

    public ValueTask DisposeAsync()
    {
        timer?.Stop();
        timer?.Dispose();
        return ValueTask.CompletedTask;
    }
}