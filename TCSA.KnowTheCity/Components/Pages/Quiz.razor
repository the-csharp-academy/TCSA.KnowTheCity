@page "/quiz/{CityId:int}"
@using System.Timers
@using Microsoft.Extensions.Options
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Core.Options
@using TCSA.KnowTheCity.Core.Services
@using TCSA.KnowTheCity.Services
@implements IAsyncDisposable

@if (_isLoading)
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper Elevation="6" Class="py-10 px-20 rounded-xl">
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.h6">Loading images… @_imagesLoaded / @_landmarks.Count</MudText>
            </MudStack>
        </MudPaper>
    </MudContainer>
}
else if (!_quizFinished && _landmarks.Count > 0 && _currentIndex < _landmarks.Count)
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper
            Elevation="6"
            Class="py-4 px-20 rounded-xl overflow-hidden">

            <MudStack AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudStack Row="true" Spacing="5" AlignItems="AlignItems.Center">
                    <MudChip T="string"
                             Color="Color.Success"
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        Quiz @(_currentIndex + 1)/@_landmarks.Count
                    </MudChip>
                    <MudChip T="string"
                             Color="@(_timeRemaining <= 10 ? Color.Error : Color.Warning)"
                             Variant="Variant.Filled"
                             Icon="@Icons.Material.Filled.Timer"
                             Size="Size.Large">
                        @TimeSpan.FromSeconds(_timeRemaining).ToString("m\\:ss")
                    </MudChip>
                    <MudChip T="string"
                             Color="Color.Secondary"
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        Score: @_correctCount
                    </MudChip>
                    @if (!string.IsNullOrEmpty(_feedbackMessage))
                    {
                        <MudAlert Severity="@_feedbackSeverity" Variant="Variant.Filled" NoIcon Dense="true">
                            @_feedbackMessage
                        </MudAlert>
                    }
                </MudStack>
            </MudStack>

                <MudProgressLinear Color="@(_timeRemaining <= 10 ? Color.Error : Color.Primary)"
                               Value="@((_timeRemaining / 60.0) * 100)"
                               Class="mb-4" Rounded="true" Size="Size.Large" />

            <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">
                Landmark @(_currentIndex + 1) of @_landmarks.Count
            </MudText>

            <div style="border-radius:16px; overflow:hidden;">
                @if (_cachedImagePaths.TryGetValue(_landmarks[_currentIndex].Name, out var imgData) && !string.IsNullOrEmpty(imgData))
                {
                    <img src="@imgData" alt="Landmark" style="width:100%;height:400px;object-fit:cover;" />
                }
                else
                {
                    <div style="width:100%;height:400px;background:#e0e0e0;display:flex;align-items:center;justify-content:center;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                    </div>
                }
            </div>

            <MudTextField @bind-Value="_currentGuess"
                          Label="Name this landmark..."
                          Variant="Variant.Outlined"
                          Immediate="true"
                          OnKeyDown="HandleKeyDown" />

            <MudGrid Class="mb-3">
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true" OnClick="SubmitGuess"
                               Style="height:56px;">
                        Answer
                    </MudButton>
                </MudItem>
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                               FullWidth="true" OnClick="SkipLandmark"
                               Style="height:56px;">
                        Skip
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
}

@code {
    [Parameter] public int CityId { get; set; }

    [Inject] private IGameService GameService { get; set; } = default!;
    [Inject] private ICityService CityService { get; set; } = default!;
    [Inject] private IImageCacheService ImageCacheService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private IOptions<ConfigOptions> Config { get; set; }

    private List<Landmark> _landmarks = [];
    private List<GameResultItem> _results = [];
    private Dictionary<string, string> _cachedImagePaths = [];
    private string _cityName = string.Empty;
    private int _currentIndex;
    private int _correctCount;
    private string _currentGuess = string.Empty;
    private string _feedbackMessage = string.Empty;
    private Severity _feedbackSeverity = Severity.Info;
    private int _timeRemaining = 60;
    private bool _quizFinished;
    private bool _isLoading = true;
    private int _imagesLoaded;
    private Timer? _timer;
    private CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        var city = await CityService.GetCityByIdAsync(CityId);
        _cityName = city?.Name ?? string.Empty;

        var landmarks = await CityService.GetLandmarksAsync(CityId);
        _landmarks = [.. landmarks.OrderBy(_ => Random.Shared.Next())];

        await CacheAllImagesAsync();

        _isLoading = false;

        _timer = new Timer(1000);
        _timer.Elapsed += OnTimerElapsed;
        _timer.Start();
    }

    private async Task CacheAllImagesAsync()
    {
        foreach (var landmark in _landmarks)
        {
            var relativePath = CityDataHelper.GetLandmarkImagePath(_cityName, landmark.Name);

            try
            {
                var localPath = await ImageCacheService.GetImagePathAsync(relativePath, _cts.Token);
                _cachedImagePaths[landmark.Name] = ImageHelpers.ConvertToBase64DataUri(localPath);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Quiz] Failed to cache image for {landmark.Name}: {ex.Message}");
                _cachedImagePaths[landmark.Name] = relativePath;
            }

            _imagesLoaded++;
            StateHasChanged();
        }
    }

    private string GetCachedImagePath(string landmarkName) =>
        _cachedImagePaths.TryGetValue(landmarkName, out var path)
            ? path
            : CityDataHelper.GetLandmarkImagePath(_cityName, landmarkName);

    private async void OnTimerElapsed(object? sender, ElapsedEventArgs e)
    {
        if (_quizFinished)
            return;

        _timeRemaining--;

        if (_timeRemaining <= 0)
            await InvokeAsync(FinishQuizAsync);
        else
            await InvokeAsync(StateHasChanged);
    }

    private async void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SubmitGuess();
    }

    private async Task SubmitGuess()
    {
        if (string.IsNullOrWhiteSpace(_currentGuess) || _quizFinished)
            return;

        var expected = _landmarks[_currentIndex];
        var isCorrect = string.Equals(expected.Name, _currentGuess.Trim(), StringComparison.OrdinalIgnoreCase);

        if (isCorrect)
        {
            _results.Add(new() { LandmarkId = expected.Id, IsCorrect = true });
            _correctCount++;
            _feedbackMessage = $"Correct! {expected.Name}";
            _feedbackSeverity = Severity.Success;
        }
        else
        {
            _results.Add(new() { LandmarkId = expected.Id, IsCorrect = false, Label = "wrong answer" });
            _feedbackMessage = $"Wrong! The answer was: {expected.Name}";
            _feedbackSeverity = Severity.Error;
        }

        _currentGuess = "";
        await MoveToNextAsync();
    }

    private async Task SkipLandmark()
    {
        var expected = _landmarks[_currentIndex];
        _results.Add(new() { LandmarkId = expected.Id, IsCorrect = false, Label = "skipped" });
        _feedbackMessage = $"The answer was: {expected.Name}";
        _feedbackSeverity = Severity.Error;
        _currentGuess = string.Empty;
        await MoveToNextAsync();
    }

    private async Task MoveToNextAsync()
    {
        _currentIndex++;

        if (_currentIndex >= _landmarks.Count)
            await FinishQuizAsync();
    }

    private async Task FinishQuizAsync()
    {
        if (_quizFinished)
            return;

        _quizFinished = true;
        _timer?.Stop();

        for (var i = _results.Count; i < _landmarks.Count; i++)
        {
            _results.Add(new() { LandmarkId = _landmarks[i].Id, IsCorrect = false, Label = "timed out" });
        }

        var gameResult = new GameResult
        {
            CityId = CityId,
            CorrectCount = _correctCount,
            TotalCount = _landmarks.Count,
            PlayedAt = DateTime.Now,
            Items = _results
        };

        var id = await GameService.SaveGameResultAsync(gameResult);
        Navigation.NavigateTo($"/results/{id}");
    }

    public async ValueTask DisposeAsync()
    {
        await _cts.CancelAsync();
        _cts.Dispose();
        _timer?.Stop();
        _timer?.Dispose();
    }
}