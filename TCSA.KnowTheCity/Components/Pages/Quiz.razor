@page "/quiz/{CityId:int}"
@using System.Timers
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Services
@implements IAsyncDisposable

@if (!_quizFinished && _landmarks.Count > 0 && _currentIndex < _landmarks.Count)
{
    <MudContainer MaxWidth="MaxWidth.Medium">
        <MudPaper
            Elevation="6"
            Class="py-4 px-20 rounded-xl overflow-hidden">

            <MudStack AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudStack Row="true" Spacing="5" AlignItems="AlignItems.Center">
                    <MudChip T="string"
                             Color="Color.Success"
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        Quiz @(_currentIndex + 1)/@_landmarks.Count
                    </MudChip>
                    <MudChip T="string"
                             Color="@(_timeRemaining <= 10 ? Color.Error : Color.Warning)"
                             Variant="Variant.Filled"
                             Icon="@Icons.Material.Filled.Timer"
                             Size="Size.Large">
                        @TimeSpan.FromSeconds(_timeRemaining).ToString("m\\:ss")
                    </MudChip>
                    <MudChip T="string"
                             Color="Color.Secondary"
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        Score: @_correctCount
                    </MudChip>
                    @if (!string.IsNullOrEmpty(_feedbackMessage))
                    {
                        <MudAlert Severity="@_feedbackSeverity" Variant="Variant.Filled" NoIcon Dense="true">
                            @_feedbackMessage
                        </MudAlert>
                    }
                </MudStack>
            </MudStack>

                <MudProgressLinear Color="@(_timeRemaining <= 10 ? Color.Error : Color.Primary)"
                               Value="@((_timeRemaining / 60.0) * 100)"
                               Class="mb-4" Rounded="true" Size="Size.Large" />

            <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">
                Landmark @(_currentIndex + 1) of @_landmarks.Count
            </MudText>

            <div style="border-radius:16px; overflow:hidden;">
                <MudCardMedia 
                              Image="@CityDataHelper.GetLandmarkImagePath(_cityName, _landmarks[_currentIndex].Name)"
                              Height="400" />
            </div>

            <MudTextField @bind-Value="_currentGuess"
                          Label="Name this landmark..."
                          Variant="Variant.Outlined"
                          Immediate="true"
                          OnKeyDown="HandleKeyDown" />

            <MudGrid Class="mb-3">
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true" OnClick="SubmitGuess"
                               Style="height:56px;">
                        Answer
                    </MudButton>
                </MudItem>
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled" Color="Color.Error"
                               FullWidth="true" OnClick="SkipLandmark"
                               Style="height:56px;">
                        Skip
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
}

@code {
    [Parameter]
    public int CityId { get; set; }

    [Inject]
    private IGameService GameService { get; set; } = default!;

    [Inject]
    private ICityService CityService { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private List<Landmark> _landmarks = [];
    private List<GameResultItem> _results = [];
    private string _cityName = string.Empty;
    private int _currentIndex;
    private int _correctCount;
    private string _currentGuess = string.Empty;
    private string _feedbackMessage = string.Empty;
    private Severity _feedbackSeverity = Severity.Info;
    private int _timeRemaining = 60;
    private bool _quizFinished;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        var city = await CityService.GetCityByIdAsync(CityId);
        _cityName = city?.Name ?? string.Empty;

        var landmarks = await CityService.GetLandmarksAsync(CityId);
        _landmarks = [.. landmarks.OrderBy(_ => Random.Shared.Next())];

        _timer = new Timer(1000);
        _timer.Elapsed += OnTimerElapsed;
        _timer.Start();
    }

    private async void OnTimerElapsed(object? sender, ElapsedEventArgs e)
    {
        if (_quizFinished)
            return;

        _timeRemaining--;

        if (_timeRemaining <= 0)
            await InvokeAsync(FinishQuizAsync);
        else
            await InvokeAsync(StateHasChanged);
    }

    private async void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SubmitGuess();
    }

    private async Task SubmitGuess()
    {
        if (string.IsNullOrWhiteSpace(_currentGuess) || _quizFinished)
            return;

        var expected = _landmarks[_currentIndex];
        var isCorrect = string.Equals(expected.Name, _currentGuess.Trim(), StringComparison.OrdinalIgnoreCase);

        if (isCorrect)
        {
            _results.Add(new() { LandmarkId = expected.Id, IsCorrect = true });
            _correctCount++;
            _feedbackMessage = $"Correct! {expected.Name}";
            _feedbackSeverity = Severity.Success;
        }
        else
        {
            _results.Add(new() { LandmarkId = expected.Id, IsCorrect = false, Label = "wrong answer" });
            _feedbackMessage = $"Wrong! The answer was: {expected.Name}";
            _feedbackSeverity = Severity.Error;
        }

        _currentGuess = "";
        await MoveToNextAsync();
    }

    private async Task SkipLandmark()
    {
        var expected = _landmarks[_currentIndex];
        _results.Add(new() { LandmarkId = expected.Id, IsCorrect = false, Label = "skipped" });
        _feedbackMessage = $"The answer was: {expected.Name}";
        _feedbackSeverity = Severity.Error;
        _currentGuess = string.Empty;
        await MoveToNextAsync();
    }

    private async Task MoveToNextAsync()
    {
        _currentIndex++;

        if (_currentIndex >= _landmarks.Count)
            await FinishQuizAsync();
    }

    private async Task FinishQuizAsync()
    {
        if (_quizFinished)
            return;

        _quizFinished = true;
        _timer?.Stop();

        for (var i = _results.Count; i < _landmarks.Count; i++)
        {
            _results.Add(new() { LandmarkId = _landmarks[i].Id, IsCorrect = false, Label = "timed out" });
        }

        var gameResult = new GameResult
        {
            CityId = CityId,
            CorrectCount = _correctCount,
            TotalCount = _landmarks.Count,
            PlayedAt = DateTime.Now,
            Items = _results
        };

        var id = await GameService.SaveGameResultAsync(gameResult);
        Navigation.NavigateTo($"/results/{id}");
    }

    public ValueTask DisposeAsync()
    {
        _timer?.Stop();
        _timer?.Dispose();
        return ValueTask.CompletedTask;
    }
}