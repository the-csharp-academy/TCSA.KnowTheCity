@page "/study"
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Core.Services
@using TCSA.KnowTheCity.Services

<MudContainer MaxWidth="MaxWidth.Large" Class="study-page pb-8">
    <MudPaper Elevation="0" Class="study-hero mb-6">
        <MudStack Spacing="3">
            <MudChip T="string"
                     Class="study-hero-chip"
                     Variant="Variant.Filled"
                     Icon="@Icons.Material.Filled.MenuBook">
                Study Mode
            </MudChip>

            <MudText Typo="Typo.h4" Class="study-hero-title">
                Pick a city and review landmarks at your own pace
            </MudText>

            <MudText Typo="Typo.body1" Class="study-hero-subtitle">
                Warm up before a quiz by exploring each city and getting familiar with its landmarks.
            </MudText>

            <MudStack Row="true" Spacing="2" Class="study-hero-chips">
                <MudChip T="string"
                         Class="brand-chip brand-chip-gold"
                         Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.LocationCity">
                    @CityCountLabel
                </MudChip>

                <MudChip T="string"
                         Class="brand-chip study-hero-chip-secondary"
                         Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.Visibility">
                    Review landmarks
                </MudChip>

                <MudChip T="string"
                         Class="brand-chip brand-chip-orange"
                         Variant="Variant.Filled"
                         Icon="@Icons.Material.Filled.School">
                    Quiz prep
                </MudChip>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudText Typo="Typo.body1" Class="study-intro mb-4">
        Select a city to study its landmarks.
    </MudText>

    <MudGrid>
        @foreach (var city in _cities)
        {
            <MudItem xs="6" sm="4" md="3">
                <MudCard Elevation="6"
                         Class="city-card study-city-card"
                         @onclick="() => NavigateToStudy(city.Id)"
                         Style="cursor:pointer;">
                    @if (_cityImagePaths.TryGetValue(city.Id, out var imgData) && !string.IsNullOrEmpty(imgData))
                    {
                        <img src="@imgData" alt="@city.Name" style="width:100%;height:200px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="study-city-card-placeholder">
                            <MudProgressCircular Indeterminate="true" Color="Color.Warning" Size="Size.Small" />
                        </div>
                    }

                    <MudCardContent Class="study-city-card-content">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h6" Class="study-city-card-title">@city.Name</MudText>
                            <MudText Typo="Typo.caption" Class="study-city-card-caption">Open study guide</MudText>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ICityService CityService { get; set; } = default!;
    [Inject] private IImageCacheService ImageCache { get; set; } = default!;

    private List<City> _cities = [];
    private readonly Dictionary<int, string> _cityImagePaths = [];

    private string CityCountLabel =>
        _cities.Count == 1 ? "1 city ready" : $"{_cities.Count} cities ready";

    protected override async Task OnInitializedAsync()
    {
        _cities = await CityService.GetCitiesAsync();
        StateHasChanged();

        foreach (var city in _cities)
        {
            try
            {
                var relativePath = CityDataHelper.GetCityImagePath(city.Name);
                var localPath = await ImageCache.GetImagePathAsync(relativePath);
                _cityImagePaths[city.Id] = ImageHelpers.ConvertToBase64DataUri(localPath);
            }
            catch
            {
                _cityImagePaths[city.Id] = string.Empty;
            }
        }

        StateHasChanged();
    }

    private void NavigateToStudy(int cityId) => Navigation.NavigateTo($"study/{cityId}");
}