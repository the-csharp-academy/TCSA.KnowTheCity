@page "/study/{CityId:int}"
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Core.Models.Domain
@using TCSA.KnowTheCity.Core.Services
@using TCSA.KnowTheCity.Services

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="8" Class="study-shell py-4 px-6 mt-10 rounded-xl overflow-hidden">
        <MudStack Spacing="3" Class="mb-3">
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string"
                         Class="study-city-chip"
                         Variant="Variant.Filled"
                         Size="Size.Large">
                    @_cityName
                </MudChip>

                @if (_landmarks.Count > 0)
                {
                    <MudChip T="string"
                             Class="study-progress-chip"
                             Variant="Variant.Filled"
                             Size="Size.Large">
                        Study @(currentIndex + 1)/@_landmarks.Count
                    </MudChip>
                }
            </MudStack>
        </MudStack>

        @if (_landmarks.Count > 0)
        {           
            <MudPaper Elevation="0" Class="study-landmark-banner pa-4 mb-4">
                <MudText Typo="Typo.subtitle2" Class="study-landmark-subtitle">
                    Landmark @(currentIndex + 1) of @_landmarks.Count
                </MudText>
                <MudText Typo="Typo.h5" Class="study-landmark-title">
                    @_landmarks[currentIndex].Name
                </MudText>
            </MudPaper>

            <div class="study-image-frame mb-4">
                @if (_cachedImagePaths.TryGetValue(_landmarks[currentIndex].Name, out var imgData) && !string.IsNullOrEmpty(imgData))
                {
                    <img src="@imgData" alt="@_landmarks[currentIndex].Name" style="width:100%;height:400px;object-fit:cover;" />
                }
                else
                {
                    <div class="study-image-placeholder">
                        <MudProgressCircular Indeterminate="true" Color="Color.Info" Size="Size.Small" />
                    </div>
                }
            </div>

            <MudGrid Class="mb-3">
                @if (currentIndex > 0)
                {
                    <MudItem xs="6">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Secondary"
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   Class="study-action-button study-action-button-secondary"
                                   OnClick="Previous">
                            Previous
                        </MudButton>
                    </MudItem>
                }
                @if (currentIndex < _landmarks.Count - 1)
                {
                    <MudItem xs="@(currentIndex > 0 ? 6 : 12)">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   Class="study-action-button study-action-button-primary"
                                   OnClick="Next">
                            Next
                        </MudButton>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="@(currentIndex > 0 ? 6 : 12)">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   Class="study-action-button study-action-button-primary"
                                   OnClick="Finish">
                            Finish
                        </MudButton>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public int CityId { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ICityService CityService { get; set; } = default!;
    [Inject] private IImageCacheService ImageCacheService { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<Landmark> _landmarks = [];
    private Dictionary<string, string> _cachedImagePaths = [];
    private string _cityName = "";
    private int currentIndex;

    protected override async Task OnInitializedAsync()
    {
        var city = await CityService.GetCityByIdAsync(CityId);
        _cityName = city?.Name ?? "";

        if (city is null)
        {
            Snackbar.Add("Error loading landmarks", Severity.Error);
            return;
        }

        var landmarks = await CityService.GetLandmarksAsync(city.RemoteId);
        if (landmarks is null || landmarks.Count == 0)
        {
            Snackbar.Add("Error loading landmarks", Severity.Error);
            return;
        }

        _landmarks = [.. landmarks.OrderBy(_ => Random.Shared.Next())];

        foreach (var landmark in _landmarks)
        {
            try
            {
                var localPath = await ImageCacheService.GetImagePathAsync(landmark.ImagePath);
                _cachedImagePaths[landmark.Name] = ImageHelpers.ConvertToBase64DataUri(localPath);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[StudyCity] Failed to cache image for {landmark.Name}: {ex.Message}");
                _cachedImagePaths[landmark.Name] = string.Empty;
            }
        }
    }

    private void Previous()
    {
        if (currentIndex > 0)
            currentIndex--;
    }

    private void Next()
    {
        if (currentIndex < _landmarks.Count - 1)
            currentIndex++;
    }

    private void Finish() => Navigation.NavigateTo("/");
}