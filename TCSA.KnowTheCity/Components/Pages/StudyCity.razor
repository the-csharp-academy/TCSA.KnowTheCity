@page "/study/{CityId:int}"
@using TCSA.KnowTheCity.Core.Helpers
@using TCSA.KnowTheCity.Core.Models
@using TCSA.KnowTheCity.Services

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="6" Class="py-4 px-20 mt-10 rounded-xl overflow-hidden">

        <MudStack AlignItems="AlignItems.Center" Class="mb-5">
            <MudChip T="string"
                     Color="Color.Primary"
                     Variant="Variant.Filled"
                     Size="Size.Large">
                @_cityName — @(currentIndex + 1) / @_landmarks.Count
            </MudChip>
        </MudStack>

        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-2">
            @_landmarks[currentIndex].Name
        </MudText>

        <div style="border-radius:16px; overflow:hidden;">
            <MudCardMedia Image="@CityDataHelper.GetLandmarkImagePath(_cityName, _landmarks[currentIndex].Name)"
                          Height="400" />
        </div>

        <MudGrid Class="mt-4 mb-3">
            @if (currentIndex > 0)
            {
                <MudItem xs="6">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="Previous"
                               Style="height:56px;">
                        Previous
                    </MudButton>
                </MudItem>
            }
            @if (currentIndex < _landmarks.Count - 1)
            {
                <MudItem xs="@(currentIndex > 0 ? 6 : 12)">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               EndIcon="@Icons.Material.Filled.ArrowForward"
                               OnClick="Next"
                               Style="height:56px;">
                        Next
                    </MudButton>
                </MudItem>
            }
        </MudGrid>

    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public int CityId { get; set; }

    [Inject]
    private ICityService CityService { get; set; } = default!;

    private List<Landmark> _landmarks = [];
    private string _cityName = "";
    private int currentIndex;

    protected override async Task OnInitializedAsync()
    {
        var city = await CityService.GetCityByIdAsync(CityId);
        _cityName = city?.Name ?? "";
        _landmarks = [.. (await CityService.GetLandmarksAsync(CityId)).OrderBy(_ => Random.Shared.Next())];
    }

    private void Previous()
    {
        if (currentIndex > 0)
            currentIndex--;
    }

    private void Next()
    {
        if (currentIndex < _landmarks.Count - 1)
            currentIndex++;
    }
}